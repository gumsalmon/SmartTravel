@page
@model CreateUserModel
<div class="container mt-5">
    <div class="col-md-6 mx-auto card p-4 shadow-sm border-0 rounded-4">
        <h4 class="fw-bold mb-4">🆕 Tạo tài khoản chủ sạp mới</h4>
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Tên đăng nhập</label>
                <input asp-for="NewUser.Username" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu (Hệ thống sẽ tự mã hóa)</label>
                <input asp-for="Password" type="password" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Gán cho sạp hàng (Stall ID)</label>
                <input asp-for="NewUser.StallId" type="number" class="form-control" placeholder="Nhập ID sạp hàng">
            </div>
            <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">XÁC NHẬN TẠO</button>
        </form>
    </div>
</div>