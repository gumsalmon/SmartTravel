@page
@model HeriStep.Admin.Pages.AdminMapModel
@{
    ViewData["Title"] = "Bản đồ Admin";
    // Nếu sếp dùng Layout chung thì giữ nguyên, không thì thêm Layout = null;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    #vinhKhanhMap {
        height: 700px; /* Sếp thích cao bao nhiêu thì chỉnh số này */
        width: 100%;
        border-radius: 10px;
        z-index: 1; /* Để popup không bị che */
    }
</style>

<div class="container-fluid mt-4 px-4">
    <h2 class="fw-bold text-danger mb-3">🗺️ Quản lý Bản đồ Sạp (Admin)</h2>

    <div id="vinhKhanhMap" class="shadow-sm border border-2 border-danger"></div>
</div>

<script>
    // Khởi tạo bản đồ
    var map = L.map('vinhKhanhMap').setView([10.7614, 106.7036], 18);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap - HeriStep Project'
    }).addTo(map);

    var greenIcon = new L.Icon({
        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
        iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34]
    });

    var redIcon = new L.Icon({
        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
        iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34]
    });

    // ==========================================
    // 1. TẢI VÀ VẼ BẢN ĐỒ
    // ==========================================
    async function loadMapData() {
        try {
            const response = await fetch('http://127.0.0.1:5297/api/Stalls/admin-map');
            const stallsData = await response.json();

            stallsData.forEach(stall => {
                let isOwned = stall.ownerId !== null;
                let marker = L.marker([stall.lat, stall.lng], { icon: isOwned ? redIcon : greenIcon }).addTo(map);

                if (isOwned) {
                    marker.bindPopup(`
                        <div class="text-center">
                            <b class="text-danger fs-6">${stall.name}</b><br>
                            <span class="text-muted small">Đang hoạt động (Chủ ID: ${stall.ownerId})</span><br>
                            <hr class="my-2">
                            <button class="btn btn-sm btn-danger w-100 fw-bold" onclick="deleteStall(${stall.id})">
                                🗑️ Xóa sạp
                            </button>
                        </div>
                    `);
                } else {
                    marker.bindPopup(`
                        <div class="text-center">
                            <b class="text-success fs-6">🟢 SẠP VÔ CHỦ</b><br>
                            <span class="text-muted small">ID Tọa độ: ${stall.id}</span><br>
                            <hr class="my-2">
                            <button class="btn btn-sm btn-danger w-100 fw-bold" onclick="deleteStall(${stall.id})">
                                🗑️ Xóa sạp
                            </button>
                        </div>
                    `);
                }
            });
        } catch (error) {
            console.error("Lỗi tải bản đồ:", error);
            // Thêm cảnh báo nếu rớt mạng
            alert("Không thể kết nối API tải bản đồ. Nhớ chạy Project Backend nha sếp!");
        }
    }

    // ==========================================
    // 2. XÓA SẠP
    // ==========================================
    async function deleteStall(id) {
        if (!confirm('⚠️ Bạn có CHẮC CHẮN muốn xóa vĩnh viễn sạp này khỏi bản đồ không?')) return;

        try {
            const res = await fetch(`http://127.0.0.1:5297/api/Stalls/${id}`, {
                method: 'DELETE'
            });

            if (res.ok) {
                alert("🗑️ Đã xóa sạp thành công!");
                location.reload();
            } else {
                alert("❌ Lỗi: Không thể xóa sạp này!");
            }
        } catch (e) {
            alert("❌ Không thể kết nối tới Server để xóa!");
        }
    }

    // ==========================================
    // 3. CLICK BẢN ĐỒ XEM TỌA ĐỘ
    // ==========================================
    map.on('click', function(e) {
        var lat = e.latlng.lat;
        var lng = e.latlng.lng;

        L.popup()
            .setLatLng(e.latlng)
            .setContent(`
                <div class="text-center p-1">
                    <b class="text-primary">📍 Tọa độ điểm này</b><br>
                    Lat: ${lat.toFixed(6)}<br>
                    Lng: ${lng.toFixed(6)}
                </div>
            `)
            .openOn(map);
    });

    // Khởi chạy
    loadMapData();
</script>