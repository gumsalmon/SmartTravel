<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStep Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper d-flex">

        <nav class="sidebar shadow d-flex flex-column">
            <div class="p-4 mb-3 border-bottom border-secondary">
                <h4 class="fw-bold text-white m-0">HeriStep Admin</h4>
            </div>

            <div class="nav flex-column w-100">
                <a href="/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Tổng quan
                </a>
                <a href="/Stalls/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stalls/Index" ? "active" : "")">
                    <i class="bi bi-shop"></i> Quản lý sạp hàng
                </a>
                <a href="/Subscriptions/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Subscriptions/Index" ? "active" : "")">
                    <i class="bi bi-card-checklist"></i> Gói Subscription
                </a>
                <a href="/Users/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Users/Index" ? "active" : "")">
                    <i class="bi bi-people"></i> Tài khoản chủ sạp
                </a>
            </div>
            <div class="mt-auto p-4 border-top border-secondary">
                <a href="/Login" class="btn btn-outline-light btn-sm w-100">Đăng xuất</a>
            </div>
        </nav>

        <div class="main-content flex-grow-1">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>