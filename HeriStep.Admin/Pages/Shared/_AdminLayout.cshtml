<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStep Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
        /* CSS bổ sung để Sidebar trông chuyên nghiệp hơn */
        .sidebar {
            min-width: 260px;
            max-width: 260px;
            background: #212529;
            min-height: 100vh;
            color: white;
        }

            .sidebar .nav-link {
                color: rgba(255,255,255,.75);
                padding: 12px 20px;
                transition: all 0.3s;
            }

                .sidebar .nav-link:hover {
                    color: white;
                    background: rgba(255,255,255,.1);
                }

                .sidebar .nav-link.active {
                    color: white;
                    background: #0d6efd;
                    font-weight: bold;
                }

                .sidebar .nav-link i {
                    margin-right: 10px;
                    font-size: 1.1rem;
                }

        .main-content {
            background: #f8f9fa;
            min-height: 100vh;
        }
    </style>
</head>
<body>
    <div class="admin-wrapper d-flex">

        <nav class="sidebar shadow d-flex flex-column">
            <div class="p-4 mb-3 border-bottom border-secondary">
                <h4 class="fw-bold text-white m-0">
                    <i class="bi bi-intersect me-2"></i>HeriStep
                </h4>
            </div>

            <div class="nav flex-column w-100">
                <a href="/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Tổng quan
                </a>

                <a href="/Tours/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Tours/") == true ? "active" : "")">
                    <i class="bi bi-signpost-split"></i> Quản lý lộ trình
                </a>

                <a href="/Stalls/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Stalls/") == true ? "active" : "")">
                    <i class="bi bi-shop"></i> Quản lý sạp hàng
                </a>

                <a href="/Subscriptions/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Subscriptions/") == true ? "active" : "")">
                    <i class="bi bi-card-checklist"></i> Gói Subscription
                </a>

                <a href="/Users/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Users/") == true ? "active" : "")">
                    <i class="bi bi-people"></i> Tài khoản chủ sạp
                </a>
            </div>

            <div class="mt-auto p-4 border-top border-secondary">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <i class="bi bi-person-circle fs-3"></i>
                    </div>
                    <div class="flex-grow-1 ms-3 overflow-hidden">
                        <p class="mb-0 text-white small text-truncate">Quản trị viên</p>
                    </div>
                </div>
                <a href="/Login" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </div>
        </nav>

        <div class="main-content flex-grow-1">
            <header class="bg-white shadow-sm p-3 mb-4 d-flex justify-content-between align-items-center">
                <h5 class="m-0 text-secondary">@ViewData["Title"]</h5>
                <span class="badge bg-primary">HeriStep v1.0</span>
            </header>

            <div class="container-fluid px-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>