<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStep Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
        /* CSS bổ sung để Sidebar trông chuyên nghiệp hơn */
        .sidebar {
            min-width: 260px;
            max-width: 260px;
            background: #212529;
            min-height: 100vh;
            color: white;
        }

            .sidebar .nav-link {
                color: rgba(255,255,255,.75);
                padding: 12px 20px;
                transition: all 0.3s;
            }

                .sidebar .nav-link:hover {
                    color: white;
                    background: rgba(255,255,255,.1);
                }

                .sidebar .nav-link.active {
                    color: white;
                    background: #0d6efd;
                    font-weight: bold;
                }

                .sidebar .nav-link i {
                    margin-right: 10px;
                    font-size: 1.1rem;
                }

        .main-content {
            background: #f8f9fa;
            min-height: 100vh;
        }
    </style>
</head>
<body>
    <div class="admin-wrapper d-flex">

        <nav class="sidebar shadow d-flex flex-column">
            <div class="p-4 mb-3 border-bottom border-secondary">
                <h4 class="fw-bold text-white m-0">
                    <i class="bi bi-intersect me-2"></i>HeriStep
                </h4>
            </div>

            <div class="nav flex-column w-100">
                <a href="/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Tổng quan
                </a>

                <a href="/Tours/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Tours/") == true ? "active" : "")">
                    <i class="bi bi-signpost-split"></i> Quản lý lộ trình
                </a>

                <a href="/Stalls/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Stalls/") == true ? "active" : "")">
                    <i class="bi bi-shop"></i> Quản lý sạp hàng
                </a>

                <a href="/AdminMap" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/AdminMap") == true ? "active" : "")">
                    <i class="bi bi-map"></i> Bản đồ quy hoạch
                </a>

                <a href="/Subscriptions/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Subscriptions/") == true ? "active" : "")">
                    <i class="bi bi-card-checklist"></i> Gói Subscription
                </a>

                <a href="/Users/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Users/") == true ? "active" : "")">
                    <i class="bi bi-person-badge"></i> Tài khoản chủ sạp
                </a>

                <a href="/Tourists/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Tourists/") == true ? "active" : "")">
                    <i class="bi bi-people"></i> Quản lý khách du lịch
                </a>
                <a href="/PRD/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/PRD") == true ? "active" : "")">
                    <i class="bi bi-journal-richtext"></i> Tài liệu Dự án (PRD)
                </a>
            </div>

            <div class="mt-auto p-4 border-top border-secondary">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                        <i class="bi bi-person-circle fs-3"></i>
                    </div>
                    <div class="flex-grow-1 ms-3 overflow-hidden">
                        <p class="mb-0 text-white small text-truncate">Quản trị viên</p>
                    </div>
                </div>

                <a href="/Logout" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </div>
        </nav>

        <div class="main-content flex-grow-1">
            <header class="bg-white shadow-sm p-3 mb-4 d-flex justify-content-between align-items-center">
                <h5 class="m-0 text-secondary fw-bold">@ViewData["Title"]</h5>

                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-warning btn-sm fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#mockDataModal">
                        <i class="bi bi-magic me-1"></i> Tạo Dữ Liệu Ảo
                    </button>
                    <span class="badge bg-primary px-3 py-2">HeriStep v1.0</span>
                </div>
            </header>

            <div class="container-fluid px-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- 💡 MODAL MOCK DATA ĐÃ ĐƯỢC CẬP NHẬT CHÚ THÍCH -->
    <!-- ========================================== -->
    <div class="modal fade" id="mockDataModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header bg-warning text-dark border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-database-fill-gear me-2"></i> Trình tạo Mock Data</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small mb-4">Nhập số lượng bạn muốn hệ thống tự động sinh ra. Hệ thống sẽ tự động liên kết các bảng với nhau:</p>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">👥 Số lượng Chủ Sạp (Users)</label>
                        <input type="number" id="mockUserCount" class="form-control rounded-pill px-3" value="5" min="0">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">🏪 Số lượng Sạp & Gói cước</label>
                        <small class="d-block text-primary mb-2">Tự động tạo Sạp trên bản đồ + Sinh ra gói Subscription tương ứng.</small>
                        <input type="number" id="mockStallCount" class="form-control rounded-pill px-3" value="10" min="0">
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">👣 Lượt khách & Vé du lịch</label>
                        <small class="d-block text-success mb-2">Tự động tạo lịch sử truy cập + Lịch sử khách mua vé (Tourist Tickets).</small>
                        <input type="number" id="mockVisitCount" class="form-control rounded-pill px-3" value="50" min="0">
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 pe-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-dark fw-bold rounded-pill px-4 shadow" onclick="executeMockData()">🚀 CHẠY MOCK DATA</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 💡 SCRIPT GỌI API MOCK DATA -->
    <!-- Tìm đến đoạn Script cuối file và sửa lại như sau -->
    <script>
        async function executeMockData() {
            const btn = document.querySelector('button[onclick="executeMockData()"]');
            const originalText = btn.innerHTML;

            // 1. Hiệu ứng Loading cho chuyên nghiệp
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...';
            btn.disabled = true;

            // 2. Lấy dữ liệu từ các ô input
            const reqBody = {
                UserCount: parseInt(document.getElementById('mockUserCount').value) || 0,
                StallCount: parseInt(document.getElementById('mockStallCount').value) || 0,
                VisitCount: parseInt(document.getElementById('mockVisitCount').value) || 0
            };

            try {
        // Sửa dòng 173 thành thế này:
        const response = await fetch('http://localhost:5297/api/MockData/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(reqBody)
        });

                if (response.ok) {
                    alert("🎉 Tuyệt vời sếp ơi! Dữ liệu ảo đã được bơm đầy Database!");
                    location.reload();
                } else {
                    const errorText = await response.text();
                    alert("❌ API báo lỗi: " + errorText);
                }
            } catch (e) {
                alert("🧨 Không kết nối được API! Sếp nhớ kiểm tra xem Project API đã bật chưa nhé.");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>