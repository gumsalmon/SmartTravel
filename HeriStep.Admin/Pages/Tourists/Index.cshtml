@page
@model HeriStep.Admin.Pages.Tourists.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Khách du lịch";
}

<div class="container-fluid py-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">

        <div class="p-4 border-bottom d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
            <h5 class="fw-bold m-0 text-primary text-nowrap"><i class="bi bi-people-fill me-2"></i> Danh sách vé đã bán</h5>

            <div class="d-flex gap-2 flex-wrap justify-content-end">
                <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control bg-light" placeholder="Tìm mã vé, mã thiết bị...">
                    </div>

                    <div class="input-group input-group-sm" style="width: 130px;">
                        <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control bg-light" title="Từ ngày">
                    </div>
                    <span class="text-muted fw-bold">-</span>
                    <div class="input-group input-group-sm" style="width: 130px;">
                        <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control bg-light" title="Đến ngày">
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm px-3"><i class="bi bi-search me-1"></i> Lọc</button>

                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.StartDate.HasValue || Model.EndDate.HasValue)
                    {
                        <a href="/Tourists/Index" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc"><i class="bi bi-x-lg"></i></a>
                    }
                </form>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="px-4 py-3">Mã Vé</th>
                            <th class="py-3">Mã Thiết Bị (Khách)</th>
                            <th class="py-3">Gói Sử Dụng</th>
                            <th class="py-3">Số Tiền</th>
                            <th class="py-3">Ngày Kích Hoạt</th>
                            <th class="py-3">Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Tourists.Any())
                        {
                            foreach (var item in Model.Tourists)
                            {
                                <tr>
                                    <td class="px-4 fw-bold text-dark">@item.TicketCode</td>
                                    <td>
                                        <span class="text-secondary"><i class="bi bi-phone me-1"></i>@item.DeviceId</span>
                                    </td>
                                    <td><span class="badge bg-info-subtle text-dark border border-info">@item.PackageName</span></td>

                                    <td class="fw-bold text-success">+@(item.AmountPaid?.ToString("N0") ?? "0") đ</td>

                                    <!-- 💡 Đã sửa lại vì CreatedAt là DateTime thường -->
                                    <td class="text-muted small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td>
                                        <!-- 💡 Đã sửa lại vì ExpiryDate là DateTime thường -->
                                        @if (item.ExpiryDate > DateTime.Now)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-3 rounded-pill">Đang hiệu lực</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger px-3 rounded-pill">Hết hạn</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Không tìm thấy dữ liệu vé phù hợp!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BỘ PHÂN TRANG THÔNG MINH -->
        <div class="card-footer bg-white p-3 border-top d-flex justify-content-between align-items-center">
            <span class="text-muted small">Trang <strong>@Model.CurrentPage</strong> / @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>

            @if (Model.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link shadow-none" href="/Tourists/Index?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")">Trước</a>
                        </li>

                        @{
                            int startPage = Math.Max(1, Model.CurrentPage - 2);
                            int endPage = Math.Min(Model.TotalPages, startPage + 4);
                            if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link shadow-none" href="/Tourists/Index?PageNumber=@i&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link shadow-none" href="/Tourists/Index?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>