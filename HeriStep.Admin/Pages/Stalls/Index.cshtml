@page
@model HeriStep.Admin.Pages.Stalls.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý sạp hàng";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    .bulk-actions-bar {
        display: none;
        position: sticky;
        top: 10px;
        z-index: 1020;
        background: #fff;
        border: 2px solid #0d6efd;
    }

    .page-link {
        border-radius: 8px !important;
        margin: 0 3px;
    }
</style>

<div class="container-fluid py-4">

    <!-- 💡 THANH THAO TÁC HÀNG LOẠT (Hiện khi sếp chọn > 0 sạp) -->
    <div class="bulk-actions-bar shadow-lg p-3 mb-4 rounded-4 animate__animated animate__fadeInDown">
        <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold text-primary ms-2">📦 Đã chọn <span id="selected-count">0</span> sạp</span>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#bulkAssignModal">
                    <i class="bi bi-person-plus me-1"></i> Gán chủ hàng loạt
                </button>
                <button type="button" class="btn btn-light btn-sm rounded-pill" onclick="unselectAll()">Bỏ chọn</button>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
            <h4 class="fw-bold m-0 text-dark"><i class="bi bi-shop me-2 text-primary"></i> Quản lý sạp hàng</h4>

            <div class="d-flex gap-2">
                <form method="get" class="input-group input-group-sm" style="width: 300px;">
                    <input type="text" asp-for="SearchTerm" class="form-control bg-light" placeholder="Tìm tên sạp...">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                </form>
                <a href="/AdminMap" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-geo-alt-fill me-1"></i> Thêm sạp mới
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 40px;"><input type="checkbox" id="selectAll" class="form-check-input"></th>
                        <th>Thông tin Sạp</th>
                        <th>Chủ quản lý</th>
                        <th class="text-center">Vị trí</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Stalls)
                    {
                        <tr>
                            <td class="ps-4">
                                <input type="checkbox" name="SelectedStallIds" value="@s.Id" class="form-check-input stall-checkbox">
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@s.Name</div>
                                <div class="text-muted extra-small">ID: #@s.Id | @s.RadiusMeter m</div>
                            </td>
                            <td>
                                <span class="badge @(s.OwnerId != null ? "bg-info-subtle text-info" : "bg-light text-muted") border px-2">
                                    @(s.OwnerName ?? "Chưa gán chủ")
                                </span>
                            </td>
                            <td class="text-center small text-muted">@s.Latitude, @s.Longitude</td>
                            <td class="text-center">
                                <span class="badge @(s.IsOpen ? "bg-success" : "bg-danger") rounded-pill px-3">
                                    @(s.IsOpen ? "Mở" : "Đóng")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-outline-primary border-0 rounded-circle"
                                            data-bs-toggle="modal" data-bs-target="#editStallModal"
                                            data-id="@s.Id" data-name="@s.Name" data-lat="@s.Latitude"
                                            data-lng="@s.Longitude" data-radius="@s.RadiusMeter"
                                            data-owner="@s.OwnerId" data-isopen="@(s.IsOpen ? "true" : "false")"
                                            onclick="fillEditModal(this)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" onsubmit="return confirm('Xóa sạp?')">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle"><i class="bi bi-trash3"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 💡 PHÂN TRANG (Chuẩn đồ án) -->
        <div class="card-footer bg-white p-3 border-top d-flex justify-content-between align-items-center">
            <span class="text-muted small">Trang @Model.CurrentPage / @Model.TotalPages</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="/Stalls/Index?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm">Trước</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Stalls/Index?PageNumber=@i&SearchTerm=@Model.SearchTerm">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="/Stalls/Index?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Bulk Assign -->
<div class="modal fade" id="bulkAssignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <form method="post" asp-page-handler="BulkAssign">
                <div class="modal-body p-4 text-center">
                    <h5 class="fw-bold">Gán chủ hàng loạt</h5>
                    <div id="bulk-ids-container"></div>
                    <select name="NewOwnerId" class="form-select mb-3">
                        @foreach (var o in Model.Owners)
                        {
                            <option value="@o.Id">@o.FullName</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">XÁC NHẬN</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Edit (Giữ nguyên logic sếp đang có) -->
<div class="modal fade" id="editStallModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Edit">
                <div class="modal-body p-4">
                    <h5 class="fw-bold mb-3 text-warning">✏️ Chỉnh sửa sạp</h5>
                    <input type="hidden" id="edit-id" asp-for="EditStall.Id" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Chủ sạp</label>
                        <select id="edit-owner" asp-for="EditStall.OwnerId" class="form-select select2-modal" style="width: 100%;">
                            @foreach (var o in Model.Owners)
                            {
                                <option value="@o.Id">@o.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên sạp</label>
                        <input type="text" id="edit-name" asp-for="EditStall.Name" class="form-control">
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Bán kính (m)</label>
                            <input type="number" id="edit-radius" asp-for="EditStall.RadiusMeter" class="form-control">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Trạng thái</label>
                            <select id="edit-isopen" asp-for="EditStall.IsOpen" class="form-select">
                                <option value="true">Mở</option>
                                <option value="false">Đóng</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 rounded-pill py-2 fw-bold text-white shadow-sm">LƯU THAY ĐỔI</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            // Hiệu ứng Bulk Bar
            $('.stall-checkbox, #selectAll').on('change', function() {
                if($('#selectAll').is(':checked')) $('.stall-checkbox').prop('checked', true);
                let count = $('.stall-checkbox:checked').length;
                $('#selected-count').text(count);
                count > 0 ? $('.bulk-actions-bar').fadeIn() : $('.bulk-actions-bar').fadeOut();
            });

            // Khi mở Bulk Modal: Nạp IDs vào form
            $('#bulkAssignModal').on('show.bs.modal', function() {
                let container = $('#bulk-ids-container');
                container.empty();
                $('.stall-checkbox:checked').each(function() {
                    container.append(`<input type="hidden" name="SelectedStallIds" value="${$(this).val()}">`);
                });
            });

            // Khởi tạo Select2
            $('#editStallModal').on('shown.bs.modal', function () {
                $('#edit-owner').select2({ dropdownParent: $('#editStallModal') });
            });
        });

        function fillEditModal(btn) {
            $('#edit-id').val($(btn).data('id'));
            $('#edit-name').val($(btn).data('name'));
            $('#edit-radius').val($(btn).data('radius'));
            $('#edit-isopen').val($(btn).data('isopen').toString());
            $('#edit-owner').val($(btn).data('owner')).trigger('change');
        }

        function unselectAll() { $('.stall-checkbox, #selectAll').prop('checked', false); $('.bulk-actions-bar').fadeOut(); }
    </script>
}