@page
@model HeriStep.Admin.Pages.Stalls.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý sạp hàng";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="container-fluid py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white">
            <h4 class="fw-bold m-0 text-dark"><i class="bi bi-shop me-2 text-primary"></i> Quản lý sạp hàng</h4>

            <div class="d-flex gap-2 align-items-center">
                <form method="get" class="d-flex m-0">
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <input type="text" asp-for="SearchTerm" class="form-control bg-light border-0" placeholder="Tìm tên sạp...">
                        <button type="submit" class="btn btn-light bg-light border-0"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <a href="/AdminMap" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-geo-alt-fill me-1"></i> Thêm sạp trên Bản đồ
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 border-0">Thông tin Sạp</th>
                        <th class="border-0">Chủ quản lý (SĐT)</th>
                        <th class="border-0 text-center">Vị trí (Lat, Lng)</th>
                        <th class="border-0 text-center">Bán kính</th>
                        <th class="border-0 text-center">Trạng thái</th>
                        <th class="border-0 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Stalls.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có sạp hàng nào được tạo.</td></tr>
                    }
                    @foreach (var s in Model.Stalls)
                    {
                        var ownerInfo = Model.Owners.FirstOrDefault(o => o.Id == (int?)s.OwnerId);
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@s.Name</div>
                                <div class="text-muted extra-small">Mã: HS-@s.Id.ToString("D4") | @s.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td>
                                @if (ownerInfo != null)
                                {
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold small text-dark">@ownerInfo.FullName</span>
                                        <span class="text-muted extra-small"><i class="bi bi-phone"></i> @ownerInfo.Username</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border px-2">Chưa gán chủ</span>
                                }
                            </td>
                            <td class="text-center">
                                <code class="small text-secondary">@s.Latitude, @s.Longitude</code>
                            </td>
                            <td class="text-center">@s.RadiusMeter m</td>
                            <td class="text-center">
                                <span class="badge @(s.IsOpen ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") rounded-pill px-3">
                                    @(s.IsOpen ? "Đang mở" : "Đã đóng")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary border-0 rounded-circle"
                                            data-bs-toggle="modal" data-bs-target="#editStallModal"
                                            data-id="@s.Id" data-name="@s.Name" data-lat="@s.Latitude"
                                            data-lng="@s.Longitude" data-radius="@s.RadiusMeter"
                                            data-owner="@s.OwnerId" data-isopen="@(s.IsOpen ? "true" : "false")"
                                            onclick="fillEditModal(this)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa sạp @s.Name?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center bg-light">
            <span class="text-muted small">Trang @Model.CurrentPage / @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>
            @if (Model.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link shadow-none" href="/Stalls/Index?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm">Trước</a>
                        </li>
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link shadow-none" href="/Stalls/Index?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="editStallModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-warning">✏️ Chỉnh sửa sạp hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Edit">
                    <input type="hidden" id="edit-id" asp-for="EditStall.Id" />

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Chủ sạp quản lý <span class="text-danger">*</span></label>
                        <select id="edit-owner" asp-for="EditStall.OwnerId" class="form-select select2-modal" style="width: 100%;">
                            @foreach (var owner in Model.Owners)
                            {
                                <option value="@owner.Id">@owner.FullName (@owner.Username)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Tên sạp <span class="text-danger">*</span></label>
                        <input type="text" id="edit-name" asp-for="EditStall.Name" class="form-control rounded-3">
                        <span asp-validation-for="EditStall.Name" class="text-danger extra-small fw-bold"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Bán kính quét (m)</label>
                            <input type="number" id="edit-radius" asp-for="EditStall.RadiusMeter" class="form-control rounded-3">
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Trạng thái</label>
                            <select id="edit-isopen" asp-for="EditStall.IsOpen" class="form-select rounded-3">
                                <option value="true">Đang mở</option>
                                <option value="false">Đã đóng</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3 small">
                        <div class="col-6">
                            <label class="text-muted extra-small">Vĩ độ</label>
                            <input type="number" step="any" id="edit-lat" asp-for="EditStall.Latitude" class="form-control rounded-3 bg-light">
                        </div>
                        <div class="col-6">
                            <label class="text-muted extra-small">Kinh độ</label>
                            <input type="number" step="any" id="edit-lng" asp-for="EditStall.Longitude" class="form-control rounded-3 bg-light">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 rounded-pill py-2 fw-bold mt-2 shadow-sm text-white">CẬP NHẬT THÔNG TIN</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/vi.js"></script>

    <script>
        $(document).ready(function() {
            // Tự động ẩn Alert sau 4 giây
            window.setTimeout(function() {
                $(".alert").fadeTo(500, 0).slideUp(500, function(){
                    $(this).remove();
                });
            }, 4000);

            // Khởi tạo Select2 cho Modal Edit
            function initSelect2(modalId, selectId) {
                $(modalId).on('shown.bs.modal', function () {
                    $(selectId).select2({
                        dropdownParent: $(modalId),
                        language: "vi",
                        placeholder: "-- Tìm chủ sạp --",
                        allowClear: true
                    });
                });
            }

            initSelect2('#editStallModal', '#edit-owner');
        });

        function fillEditModal(btn) {
            document.getElementById('edit-id').value = btn.getAttribute('data-id');
            document.getElementById('edit-name').value = btn.getAttribute('data-name');
            document.getElementById('edit-lat').value = btn.getAttribute('data-lat');
            document.getElementById('edit-lng').value = btn.getAttribute('data-lng');
            document.getElementById('edit-radius').value = btn.getAttribute('data-radius');

            const isOpen = btn.getAttribute('data-isopen') === "true";
            document.getElementById('edit-isopen').value = isOpen.toString();

            let ownerId = btn.getAttribute('data-owner');
            $('#edit-owner').val(ownerId ? ownerId : "").trigger('change');
        }
    </script>
}