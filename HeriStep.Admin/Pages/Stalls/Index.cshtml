@page
@model HeriStep.Admin.Pages.Stalls.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý sạp hàng";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white">
            <h4 class="fw-bold m-0 text-dark"><i class="bi bi-shop me-2"></i> Quản lý sạp hàng</h4>
            <div class="d-flex gap-2 align-items-center">
                <form method="get" class="d-flex m-0">
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <input type="text" asp-for="SearchTerm" class="form-control bg-light border-0" placeholder="Tìm tên sạp...">
                        <button type="submit" class="btn btn-light bg-light border-0"><i class="bi bi-search"></i></button>
                    </div>
                </form>
                <button class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#createStallModal">
                    <i class="bi bi-plus-lg me-1"></i> Thêm sạp mới
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 border-0">Tên Sạp</th>
                        <th class="border-0">Chủ quản lý</th>
                        <th class="border-0 text-center">Tọa độ</th>
                        <th class="border-0 text-center">Bán kính</th>
                        <th class="border-0 text-center">Trạng thái</th>
                        <th class="border-0 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Stalls.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">Chưa có sạp hàng nào.</td></tr>
                    }
                    @foreach (var s in Model.Stalls)
                    {
                        var ownerInfo = Model.Owners.FirstOrDefault(o => o.Id == s.OwnerId);
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@s.Name</div>
                                <div class="text-muted extra-small">Cập nhật: @s.UpdatedAt.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td>
                                @if (ownerInfo != null)
                                {
                                    <span class="badge bg-primary-light text-primary border border-primary-subtle">
                                        <i class="bi bi-person-fill me-1"></i> @ownerInfo.Username
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted">Chưa gán</span>
                                }
                            </td>
                            <td class="text-center"><span class="badge bg-light text-muted fw-normal">@s.Latitude, @s.Longitude</span></td>
                            <td class="text-center">@s.RadiusMeter m</td>
                            <td class="text-center">
                                <span class="badge @(s.IsOpen ? "bg-success" : "bg-danger") rounded-pill px-3">
                                    @(s.IsOpen ? "Đang mở" : "Đã đóng")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn btn-action-round text-primary bg-light border-0"
                                            data-bs-toggle="modal" data-bs-target="#editStallModal"
                                            data-id="@s.Id" data-name="@s.Name" data-lat="@s.Latitude"
                                            data-lng="@s.Longitude" data-radius="@s.RadiusMeter" data-owner="@s.OwnerId" data-isopen="@(s.IsOpen ? "true" : "false")"
                                            onclick="fillEditModal(this)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa sạp @s.Name? Toàn bộ món ăn của sạp sẽ bị xóa theo!');">
                                        <button type="submit" class="btn btn-action-round text-danger bg-light border-0">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center bg-light">
            <span class="text-muted small">Trang @Model.CurrentPage / @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>
            @if (Model.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="/Stalls/Index?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm">Trước</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="/Stalls/Index?PageNumber=@i&SearchTerm=@Model.SearchTerm">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="/Stalls/Index?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="createStallModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm sạp hàng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Create">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Giao cho Chủ sạp <span class="text-danger">*</span></label>
                        <select id="create-owner" asp-for="NewStall.OwnerId" class="form-select" style="width: 100%;">
                            <option value="">-- Gõ tên hoặc số ĐT để tìm --</option>
                            @foreach (var owner in Model.Owners)
                            {
                                <option value="@owner.Id">@owner.Username - @owner.FullName</option>
                            }
                        </select>
                        <span asp-validation-for="NewStall.OwnerId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Tên sạp mặc định <span class="text-danger">*</span></label>
                        <input type="text" asp-for="NewStall.Name" class="form-control" required>
                        <span asp-validation-for="NewStall.Name" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Vĩ độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" asp-for="NewStall.Latitude" class="form-control" required>
                            <span asp-validation-for="NewStall.Latitude" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Kinh độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" asp-for="NewStall.Longitude" class="form-control" required>
                            <span asp-validation-for="NewStall.Longitude" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold mt-2">Thêm sạp hàng</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editStallModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Chỉnh sửa sạp hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Edit">
                    <input type="hidden" id="edit-id" asp-for="EditStall.Id" />
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Chủ sạp <span class="text-danger">*</span></label>
                        <select id="edit-owner" asp-for="EditStall.OwnerId" class="form-select" style="width: 100%;">
                            <option value="">-- Gõ tên hoặc số ĐT để tìm --</option>
                            @foreach (var owner in Model.Owners)
                            {
                                <option value="@owner.Id">@owner.Username - @owner.FullName</option>
                            }
                        </select>
                        <span asp-validation-for="EditStall.OwnerId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Tên sạp <span class="text-danger">*</span></label>
                        <input type="text" id="edit-name" asp-for="EditStall.Name" class="form-control" required>
                        <span asp-validation-for="EditStall.Name" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Vĩ độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" id="edit-lat" asp-for="EditStall.Latitude" class="form-control" required>
                            <span asp-validation-for="EditStall.Latitude" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Kinh độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" id="edit-lng" asp-for="EditStall.Longitude" class="form-control" required>
                            <span asp-validation-for="EditStall.Longitude" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Bán kính quét (m)</label>
                            <input type="number" id="edit-radius" asp-for="EditStall.RadiusMeter" class="form-control" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Trạng thái</label>
                            <select id="edit-isopen" asp-for="EditStall.IsOpen" class="form-select">
                                <option value="true">Đang mở</option>
                                <option value="false">Đã đóng</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 rounded-pill py-2 fw-bold mt-2">Cập nhật thông tin</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/vi.js"></script>

    <script>
        $(document).ready(function() {
            $('#create-owner').select2({
                dropdownParent: $('#createStallModal'),
                placeholder: "-- Gõ tên hoặc số điện thoại để tìm --",
                language: "vi" // 2. BẬT TIẾNG VIỆT Ở ĐÂY
            });

            $('#edit-owner').select2({
                dropdownParent: $('#editStallModal'),
                placeholder: "-- Gõ tên hoặc số điện thoại để tìm --",
                language: "vi" // BẬT TIẾNG VIỆT Ở ĐÂY
            });
        });

        // Hàm JS tự động đưa dữ liệu từ Bảng vào Form Sửa khi bấm nút
        function fillEditModal(btn) {
            document.getElementById('edit-id').value = btn.getAttribute('data-id');
            document.getElementById('edit-name').value = btn.getAttribute('data-name');
            document.getElementById('edit-lat').value = btn.getAttribute('data-lat');
            document.getElementById('edit-lng').value = btn.getAttribute('data-lng');
            document.getElementById('edit-radius').value = btn.getAttribute('data-radius');
            document.getElementById('edit-isopen').value = btn.getAttribute('data-isopen');

            let owner = btn.getAttribute('data-owner');
            $('#edit-owner').val(owner ? owner : "").trigger('change');
        }
    </script>
}
}