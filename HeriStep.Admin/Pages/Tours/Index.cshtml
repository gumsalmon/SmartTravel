@page
@model HeriStep.Admin.Pages.Tours.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Lộ trình";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white">
            <h4 class="fw-bold m-0 text-dark"><i class="bi bi-map me-2 text-primary"></i> Danh sách Lộ trình</h4>
            <button class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#createTourModal">
                <i class="bi bi-plus-lg me-1"></i> Thêm lộ trình
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 25%">Tên Lộ trình</th>
                        <th style="width: 30%">Mô tả</th>
                        <th class="text-center">Phân loại</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Tours.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">Chưa có dữ liệu lộ trình.</td></tr>
                    }
                    @foreach (var t in Model.Tours)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">
                                    @t.TourName
                                    @if (t.IsTopHot)
                                    {
                                        <span class="badge rounded-pill bg-danger ms-2 small" style="font-size: 0.6rem;">HOT</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small text-truncate d-inline-block" style="max-width: 250px;">
                                    @(string.IsNullOrEmpty(t.Description) ? "Chưa có mô tả" : t.Description)
                                </span>
                            </td>

                            <td class="text-center">
                                @if (t.StallCount < 4)
                                {
                                    <div class="d-flex flex-column align-items-center">
                                        <span class="badge bg-info-subtle text-info rounded-pill px-3 border border-info-subtle">
                                            <i class="bi bi-clock me-1"></i> Ngắn
                                        </span>
                                        <small class="text-muted mt-1" style="font-size: 0.75rem;">@t.StallCount quán</small>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-column align-items-center">
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 border border-primary-subtle">
                                            <i class="bi bi-signpost-2 me-1"></i> Dài
                                        </span>
                                        <small class="text-muted mt-1" style="font-size: 0.75rem;">@t.StallCount quán</small>
                                    </div>
                                }
                            </td>

                            <td class="text-center">
                                <span class="badge @(t.IsActive == true ? "text-success" : "text-danger") small">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                                    @(t.IsActive == true ? "Hoạt động" : "Tạm khóa")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-page="./Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-eye me-1"></i> Xem
                                    </a>

                                    <button type="button" class="btn btn-sm btn-light rounded-pill px-3 border"
                                            data-bs-toggle="modal" data-bs-target="#editTourModal"
                                            data-id="@t.Id" data-name="@t.TourName" data-desc="@t.Description"
                                            data-isactive="@(t.IsActive == true ? "true" : "false")"
                                            onclick="fillEditModal(this)">
                                        <i class="bi bi-pencil me-1"></i> Sửa
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createTourModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm lộ trình mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Create">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên lộ trình</label>
                        <input type="text" asp-for="NewTour.TourName" class="form-control rounded-3" placeholder="Ví dụ: Food Tour Buổi Sáng" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mô tả</label>
                        <textarea asp-for="NewTour.Description" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">LƯU LỘ TRÌNH</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editTourModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Chỉnh sửa lộ trình</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Edit">
                    <input type="hidden" id="edit-id" asp-for="EditTour.Id" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên lộ trình</label>
                        <input type="text" id="edit-name" asp-for="EditTour.TourName" class="form-control rounded-3" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mô tả</label>
                        <textarea id="edit-desc" asp-for="EditTour.Description" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Trạng thái</label>
                        <select id="edit-isactive" asp-for="EditTour.IsActive" class="form-select rounded-3">
                            <option value="true">Đang mở (Active)</option>
                            <option value="false">Đã khóa (Disabled)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow-sm">CẬP NHẬT</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() { $(".alert").fadeOut('slow'); }, 3000);
        });

        function fillEditModal(btn) {
            document.getElementById('edit-id').value = btn.getAttribute('data-id');
            document.getElementById('edit-name').value = btn.getAttribute('data-name');
            document.getElementById('edit-desc').value = btn.getAttribute('data-desc');
            const isActive = btn.getAttribute('data-isactive') === "true";
            document.getElementById('edit-isactive').value = isActive.toString();
        }
    </script>
}