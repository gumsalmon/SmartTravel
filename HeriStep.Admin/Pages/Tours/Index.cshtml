@page
@model HeriStep.Admin.Pages.Tours.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Lộ trình";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white">
            <h4 class="fw-bold m-0 text-dark">
                <i class="bi bi-map me-2 text-primary"></i> Danh sách Lộ trình
                <button class="btn btn-sm btn-light ms-3 rounded-circle shadow-sm" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise text-primary"></i>
                </button>

                <button class="btn btn-primary btn-sm ms-3 fw-bold shadow-sm rounded-pill px-3" onclick="autoAssignData()">
                    <i class="bi bi-magic"></i> Phân Bổ Sạp Tự Động
                </button>
            </h4>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 30%">Tên Lộ trình</th>
                        <th style="width: 35%">Mô tả</th>
                        <th class="text-center">Quy mô</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Tours.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">Chưa có dữ liệu lộ trình. Hệ thống sẽ tự động cập nhật!</td></tr>
                    }
                    @foreach (var t in Model.Tours)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark d-flex align-items-center">
                                    <i class="bi bi-signpost-split text-secondary me-2"></i> @t.TourName
                                    @if (t.IsTopHot)
                                    {
                                        <span class="badge rounded-pill bg-danger ms-2 small shadow-sm" style="font-size: 0.65rem;">
                                            <i class="bi bi-fire"></i> HOT
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small text-truncate d-inline-block" style="max-width: 300px;">
                                    @(string.IsNullOrEmpty(t.Description) ? "Chưa có mô tả" : t.Description)
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center">
                                    <span class="badge @(t.StallCount < 4 ? "bg-info-subtle text-info" : "bg-primary-subtle text-primary") rounded-pill px-3 border">
                                        <i class="bi @(t.StallCount < 4 ? "bi-clock" : "bi-signpost-2") me-1"></i>
                                        @(t.StallCount < 4 ? "Ngắn" : "Dài")
                                    </span>
                                    <small class="text-muted mt-1" style="font-size: 0.75rem;">@t.StallCount sạp (đang mở)</small>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge @(t.IsActive == true ? "text-success bg-success-subtle" : "text-danger bg-danger-subtle") small rounded-pill px-3">
                                    @(t.IsActive == true ? "Hoạt động" : "Tạm khóa")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="/Tours/Details/@t.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">
                                        <i class="bi bi-eye me-1"></i> Xem lộ trình
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() { $(".alert").fadeOut('slow'); }, 3000);
        });

        // 💡 HÀM MỚI: TỰ ĐỘNG PHÂN BỔ SẠP BƠ VƠ VÀO TOUR
        async function autoAssignData() {
            const check = confirm("Hệ thống sẽ dùng AI để tìm các sạp MỚI (chưa có lộ trình) và xếp chúng vào các Tour hiện có. Bạn có chắc chắn không?");
            if (!check) return;

            const btn = document.activeElement;
            const oldText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

            const token = localStorage.getItem('token');

            try {
                const response = await fetch('http://localhost:5297/api/Tours/auto-assign', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (response.ok) {
                    const data = await response.json();
                    alert("✅ " + data.message);
                    location.reload();
                } else {
                    const errorMsg = await response.text();
                    alert("⚠️ Cảnh báo: " + errorMsg);
                }
            } catch (err) {
                alert("❌ Lỗi kết nối máy chủ API.");
            } finally {
                btn.disabled = false;
                btn.innerHTML = oldText;
            }
        }
    </script>
}