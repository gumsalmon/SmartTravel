@page "{id:int}"
@model HeriStep.Admin.Pages.Tours.DetailsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Lộ trình";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <a asp-page="./Index" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Tour == null || Model.Tour.Id == 0)
    {
        <div class="alert alert-warning text-center rounded-4 shadow-sm py-5">
            <i class="bi bi-exclamation-triangle fs-1 text-warning mb-3 d-block"></i>
            <h5 class="fw-bold">Không tìm thấy thông tin lộ trình</h5>
            <p class="text-muted mb-0">Lộ trình bạn đang tìm kiếm không tồn tại hoặc đã bị xóa khỏi hệ thống.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-primary text-white">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="fw-bold mb-1">@Model.Tour.TourName</h2>
                        <p class="mb-0 opacity-75">@(string.IsNullOrEmpty(Model.Tour.Description) ? "Chưa có mô tả" : Model.Tour.Description)</p>
                    </div>
                    <span class="badge rounded-pill bg-white text-primary px-3 py-2">
                        @(Model.Tour.StallCount < 4 ? "Lộ trình Ngắn" : "Lộ trình Dài")
                    </span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-bottom-0 p-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold m-0"><i class="bi bi-list-ul me-2 text-primary"></i> Thứ tự ghé thăm (@(Model.Tour.Stalls?.Count ?? 0) quán)</h5>
                        <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#addStallModal">
                            <i class="bi bi-plus-lg me-1"></i> Thêm sạp
                        </button>
                    </div>
                    <div class="card-body p-3">
                        <ul class="list-group list-group-flush">
                            @if (Model.Tour.Stalls == null || !Model.Tour.Stalls.Any())
                            {
                                <li class="list-group-item text-center py-5 text-muted border-0">
                                    Lộ trình này hiện chưa có sạp hàng nào.
                                </li>
                            }
                            else
                            {
                                @for (int i = 0; i < Model.Tour.Stalls.Count; i++)
                                {
                                    var s = Model.Tour.Stalls[i];
                                    <li class="list-group-item p-3 mb-3 border border-start-0 border-end-0 border-bottom-0 border-top-0 shadow-sm rounded-4 border-start border-4 @(i == 0 ? "border-success" : "border-primary")">
                                        <div class="d-flex justify-content-between align-items-center">

                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0 bg-light rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem;">
                                                    @(i + 1)
                                                </div>
                                                <div class="flex-grow-1 ms-3">
                                                    <h6 class="fw-bold mb-1">@s.Name</h6>
                                                    <span class="badge @(s.IsOpen == true ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") rounded-pill mb-1">
                                                        @(s.IsOpen == true ? "Đang mở cửa" : "Đóng cửa")
                                                    </span>
                                                    <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i> Tọa độ: @s.Latitude, @s.Longitude</div>
                                                </div>
                                            </div>

                                            <div class="d-flex align-items-center gap-2">
                                                <div class="btn-group btn-group-sm shadow-sm me-2">
                                                    <form method="post" asp-page-handler="MoveStall" asp-route-tourId="@Model.Tour.Id" asp-route-stallId="@s.Id" asp-route-direction="up" class="m-0">
                                                        <button type="submit" class="btn btn-light text-secondary border rounded-start" title="Đẩy lên" @(i == 0 ? "disabled" : "")>
                                                            <i class="bi bi-chevron-up"></i>
                                                        </button>
                                                    </form>
                                                    <form method="post" asp-page-handler="MoveStall" asp-route-tourId="@Model.Tour.Id" asp-route-stallId="@s.Id" asp-route-direction="down" class="m-0">
                                                        <button type="submit" class="btn btn-light text-secondary border rounded-end" title="Đẩy xuống" @(i == Model.Tour.Stalls.Count - 1 ? "disabled" : "")>
                                                            <i class="bi bi-chevron-down"></i>
                                                        </button>
                                                    </form>
                                                </div>

                                                <form method="post" asp-page-handler="RemoveStall" asp-route-tourId="@Model.Tour.Id" asp-route-stallId="@s.Id" class="m-0" onsubmit="return confirm('Bạn muốn gỡ @s.Name khỏi lộ trình này?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">
                                                        <i class="bi bi-trash3 me-1"></i> Xóa
                                                    </button>
                                                </form>
                                            </div>

                                        </div>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 bg-light">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-info-circle fs-1 text-primary mb-3"></i>
                        <h6 class="fw-bold">Thông tin thêm</h6>
                        <p class="small text-muted">Lộ trình này bao gồm các điểm đến được sắp xếp tối ưu theo khoảng cách đi bộ.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="addStallModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm sạp vào lộ trình</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="AddStall" asp-route-tourId="@Model.Tour.Id">
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Chọn sạp (Từ danh sách có sẵn)</label>
                        <select asp-for="SelectedStallId" class="form-select rounded-3" required>
                            <option value="">-- Click để chọn sạp --</option>
                            @if (Model.AvailableStalls != null && Model.AvailableStalls.Any())
                            {
                                @foreach (var st in Model.AvailableStalls)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            }
                            else
                            {
                                <option value="" disabled>Không có sạp nào trống để thêm</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm" @(Model.AvailableStalls == null || !Model.AvailableStalls.Any() ? "disabled" : "")>
                        THÊM VÀO LỘ TRÌNH
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() { $(".alert").fadeOut('slow'); }, 3000);
        });
    </script>
}