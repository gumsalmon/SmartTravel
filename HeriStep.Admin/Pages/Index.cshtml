@page
@model IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan hệ thống";
}

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-primary-light text-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="text-end">
                        <span class="text-success small fw-bold">+12% ↑</span>
                        <div class="text-muted extra-small">Tháng này</div>
                    </div>
                </div>
                <h6 class="text-muted mb-1 small uppercase fw-bold">Tổng Khách hàng</h6>
                <h2 class="fw-bold mb-0">@Model.Stats.TotalCustomers.ToString("N0")</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-success-light text-success">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <div class="text-end">
                        <span class="text-muted small">@Model.Stalls.Count sạp</span>
                    </div>
                </div>
                <h6 class="text-muted mb-1 small uppercase fw-bold">Tổng Chủ sạp</h6>
                <h2 class="fw-bold mb-0">@Model.Stats.TotalStalls</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-warning-light text-warning">
                        <i class="bi bi-qr-code-scan"></i>
                    </div>
                    <span class="text-danger small fw-bold">-2% ↓</span>
                </div>
                <h6 class="text-muted mb-1 small uppercase fw-bold">Lượt quét QR</h6>
                <h2 class="fw-bold mb-0">@Model.Stats.TotalScans.ToString("N0")</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-info-light text-info">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <span class="text-muted small">VND</span>
                </div>
                <h6 class="text-muted mb-1 small uppercase fw-bold">Doanh thu phí</h6>
                <h2 class="fw-bold mb-0">@Model.Stats.TotalRevenue.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>