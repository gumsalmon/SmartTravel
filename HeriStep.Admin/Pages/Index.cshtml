@page
@model HeriStep.Admin.Pages.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan hệ thống";
}

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-primary-light text-primary">
                        <i class="bi bi-shop"></i>
                    </div>
                    <div class="text-end">
                        <div class="text-muted extra-small">Toàn hệ thống</div>
                    </div>
                </div>
                <h6 class="text-muted mb-1 small text-uppercase fw-bold">Tổng số sạp hàng</h6>
                <h2 class="fw-bold mb-0 text-primary">@Model.Stats.TotalStalls.ToString("N0")</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-success-light text-success">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                </div>
                <h6 class="text-muted mb-1 small text-uppercase fw-bold">Tài khoản Chủ sạp</h6>
                <h2 class="fw-bold mb-0 text-success">@Model.Stats.TotalStallOwners.ToString("N0")</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-warning-light text-warning">
                        <i class="bi bi-map"></i>
                    </div>
                    <span class="text-success small fw-bold">Đang hoạt động</span>
                </div>
                <h6 class="text-muted mb-1 small text-uppercase fw-bold">Lộ trình Tour</h6>
                <h2 class="fw-bold mb-0 text-warning">@Model.Stats.TotalTours.ToString("N0")</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card shadow-sm border-0 rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon bg-info-light text-info">
                        <i class="bi bi-cpu"></i>
                    </div>
                    <span class="text-muted small">Đang kích hoạt</span>
                </div>
                <h6 class="text-muted mb-1 small text-uppercase fw-bold">Thiết bị TTS</h6>
                <h2 class="fw-bold mb-0 text-info">@Model.Stats.ActiveDevices.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>