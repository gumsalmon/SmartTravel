@page
@model HeriStep.Merchant.Pages.StallDashboardModel
@{
    ViewData["Title"] = "Quản lý Sạp - Hệ thống Loa AI Thông Minh";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-primary">⚙️ Bảng điều khiển: @Model.StallInfo.Name</h2>
        <a asp-page="/Index" class="btn btn-outline-secondary">⬅ Quay lại danh sách</a>
    </div>

    <ul class="nav nav-pills mb-4 shadow-sm p-2 bg-white rounded" id="stallTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#info">📝 Thông tin & Lời chào</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#menu">🍜 Thực đơn món ăn</button>
        </li>
        <li class="nav-item">
            <button class="nav-link active fw-bold text-danger" data-bs-toggle="tab" data-bs-target="#broadcast">📢 Hệ thống Loa AI</button>
        </li>
    </ul>

    <div class="tab-content" id="stallTabContent">

        <div class="tab-pane fade" id="info">
            <div class="card p-4 shadow-sm border-0">
                <form id="editStallForm">
                    <input type="hidden" id="editStallId" value="@Model.CurrentStallId" />
                    <input type="hidden" id="stallOwnerId" value="@Model.StallInfo.OwnerId" />
                    <input type="hidden" id="stallRadius" value="@Model.StallInfo.RadiusMeter" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên Sạp</label>
                            <input type="text" id="stallName" class="form-control" value="@Model.StallInfo.Name" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Trạng thái hoạt động</label>
                            <select class="form-select" id="stallStatus">
                                <option value="true" selected="@(Model.StallInfo.IsOpen ? "selected" : null)">🟢 Đang mở cửa</option>
                                <option value="false" selected="@(!Model.StallInfo.IsOpen ? "selected" : null)">🔴 Tạm đóng cửa</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Hình Ảnh Sạp (Banner)</label>
                        <input type="file" id="stallImageFile" class="form-control" accept="image/*">
                        @if (!string.IsNullOrEmpty(Model.StallInfo.ImageUrl))
                        {
                            <div class="mt-2 p-2 border rounded bg-light text-center">
                                <small class="text-muted d-block mb-1 text-start">Ảnh hiện tại:</small>
                                <img src="http://127.0.0.1:5297@(Model.StallInfo.ImageUrl)" style="height: 150px; border-radius: 8px; border: 1px solid #ddd;" />
                            </div>
                        }
                    </div>
<!-- 💡 Inject SweetAlert2 cho Thông báo (UX) -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-success">🔊 Tùy chỉnh Nội dung Thuyết minh tự động (TTS)</label>

                        <!-- TAB ĐA NGÔN NGỮ -->
                        <ul class="nav nav-tabs mb-2" id="ttsLanguageTabs" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tts-vi" type="button">🇻🇳 Tiếng Việt</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tts-en" type="button">🇺🇸 Tiếng Anh</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tts-ko" type="button">🇰🇷 Tiếng Hàn</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tts-ja" type="button">🇯🇵 Tiếng Nhật</button>
                            </li>
                        </ul>

                        <div class="tab-content border border-top-0 p-3 rounded-bottom bg-light" id="ttsLanguageTabsContent">
                            <div class="tab-pane fade show active" id="tts-vi">
                                <textarea id="stallTts" class="form-control" rows="3" placeholder="Nhập lời chào bằng tiếng Việt...">@Model.StallInfo.TtsScript</textarea>
                                <small class="text-muted mt-2 d-block">Hệ thống AI sẽ tự động dịch sang 9 ngôn ngữ khác, nhưng bạn có thể tinh chỉnh thủ công các tab bên cạnh nếu cần thiết.</small>
                            </div>
                            <div class="tab-pane fade" id="tts-en">
                                <textarea id="stallTtsEn" class="form-control" rows="3" placeholder="Welcome to our stall..."></textarea>
                            </div>
                            <div class="tab-pane fade" id="tts-ko">
                                <textarea id="stallTtsKo" class="form-control" rows="3" placeholder="환영합니다..."></textarea>
                            </div>
                            <div class="tab-pane fade" id="tts-ja">
                                <textarea id="stallTtsJa" class="form-control" rows="3" placeholder="いらっしゃいませ..."></textarea>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-success fw-bold w-100 py-2 shadow" onclick="updateStallInfo()">💾 LƯU THÔNG TIN SẠP</button>
                </form>
            </div>
        </div>

        <div class="tab-pane fade" id="menu">
            <div class="row">
                <div class="col-md-5 mb-4">
                    <div class="card p-4 shadow-sm border-0 h-100 bg-light">
                        <h5 class="fw-bold mb-3 text-primary">✨ Thêm món ăn mới</h5>
                        <form id="addMenuForm">
                            <div class="mb-3">
                                <label class="form-label fw-bold small">Tên món ăn (Tiếng Việt)</label>
                                <input type="text" id="foodName" class="form-control" placeholder="VD: Ốc hương xào bơ tỏi" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold small">Giá bán (VNĐ)</label>
                                <input type="number" id="foodPrice" class="form-control" placeholder="VD: 50000" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Ảnh minh họa</label>
                                <input type="file" id="foodImageFile" class="form-control" accept="image/*" required>
                            </div>
                            <button type="button" class="btn btn-primary fw-bold w-100 py-2 shadow-sm" onclick="addFood()">➕ LƯU MÓN ĂN</button>
                        </form>
                    </div>
                </div>
                <div class="col-md-7 mb-4">
                    <div class="card p-4 shadow-sm border-0 h-100">
                        <h5 class="fw-bold mb-3">📋 Danh sách thực đơn</h5>
                        <div class="row g-3" id="foodListContainer">
                            <div class="col-12 text-center py-4 text-muted" id="emptyMenuMsg">
                                <em>Chưa có món ăn nào trong thực đơn.</em>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade show active" id="broadcast">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <div class="card p-4 shadow-sm text-center h-100 border-danger shadow border-2">
                        <h4 class="fw-bold text-danger">📢 Trình Điều Khiển Loa</h4>
                        <div class="my-4">
                            <button id="btnPlayBroadcast" class="btn btn-danger btn-lg rounded-circle shadow-lg" style="width: 100px; height: 100px;" onclick="toggleBroadcast()">
                                <h1 class="m-0" id="broadcastIcon" style="font-size: 3rem;">▶️</h1>
                            </button>
                            <div id="broadcastStatus" class="mt-3 fw-bold text-secondary">Hệ thống đang tắt</div>
                        </div>
                        <div class="alert alert-info text-start py-2 small">
                            <b>Loa đang đọc:</b> <span id="currentPlayingStatus" class="text-danger fw-bold d-block">...</span>
                        </div>
                        <div class="bg-white p-3 rounded border shadow-sm text-start">
                            <b class="d-block mb-2 text-primary border-bottom pb-1 small">🔄 Danh sách chờ (Queue):</b>
                            <ul id="audioQueueList" class="mb-0 text-primary fw-bold list-unstyled small" style="min-height: 80px;"></ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card p-4 shadow-sm h-100 bg-light border-0">
                        <h6 class="fw-bold text-primary mb-3">🧪 Mock Test 1: Thử giọng (Local)</h6>
                        <div class="row g-2 mb-4" id="langButtonsArea"></div>
                        <hr />

                        <h6 class="fw-bold text-danger mb-3">📱 Mock Test 2: Giả lập tín hiệu khách (App)</h6>
                        <p class="small text-muted mt-n2">Demo tính năng chống Spam (Cooldown 2 phút) khi khách quen đi ngang sạp nhiều lần.</p>

                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-danger fw-bold px-4 shadow-sm" onclick="triggerAppSignal('ko', 'FIXED_KOREAN_GUY')">🇰🇷 App: Khách Hàn</button>
                            <button class="btn btn-danger fw-bold px-4 shadow-sm" onclick="triggerAppSignal('en', 'FIXED_USA_GUY')">🇺🇸 App: Khách Mỹ</button>
                            <button class="btn btn-danger fw-bold px-4 shadow-sm" onclick="triggerAppSignal('ja', 'FIXED_JAPAN_GUY')">🇯🇵 App: Khách Nhật</button>
                        </div>

                        <p class="small text-muted mt-3 mb-1">Mô phỏng bão khách (Tạo ra ID ngẫu nhiên đồng bộ với Database)</p>
                        <div class="input-group mb-3 shadow-sm border rounded">
                            <span class="input-group-text bg-white fw-bold border-0 text-dark">Số lượng khách vào sạp:</span>
                            <input type="number" id="stormCount" class="form-control border-0" value="5" min="1" max="50">
                            <button class="btn btn-dark fw-bold px-4" onclick="simulateStorm()">🌪️ TẠO BÃO KHÁCH</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>

<script>
    const stallId = document.getElementById('editStallId').value;

    // DỮ LIỆU DỰ PHÒNG KHI RỚT MẠNG API DỊCH
    const mockTranslations = {
        'en': "Welcome to our food stall! Please come and try our best dishes!",
        'ja': "いらっしゃいませ！美味しい料理はいかがですか？ぜひご賞味ください！",
        'ko': "환영합니다! 맛있는 음식이 준비되어 있습니다. 꼭 한번 드셔보세요!",
        'zh': "欢迎光临！我们有最好的菜肴。请来尝尝吧！",
        'fr': "Bienvenue à notre stand! N'hésitez pas à goûter notre nourriture.",
        'es': "¡Bienvenido a nuestro puesto! Por favor, pruebe nuestra comida.",
        'ru': "Добро пожаловать! Пожалуйста, попробуйте нашу еду.",
        'th': "ยินดีต้อนรับสู่ร้านของเรา! เชิญชิมอาหารอร่อยๆ ได้เลยค่ะ",
        'de': "Willkommen an unserem Stand! Bitte probieren Sie unser leckeres Essen."
    };

    const langMap = {
        'vi': { name: "Người Việt", id: "vi-VN", flag: "🇻🇳", prefix: "vi" },
        'en': { name: "Người Âu Mỹ", id: "en-US", flag: "🇺🇸", prefix: "en" },
        'ja': { name: "Người Nhật", id: "ja-JP", flag: "🇯🇵", prefix: "ja" },
        'ko': { name: "Người Hàn", id: "ko-KR", flag: "🇰🇷", prefix: "ko" },
        'zh': { name: "Người Trung", id: "zh-CN", flag: "🇨🇳", prefix: "zh" },
        'fr': { name: "Người Pháp", id: "fr-FR", flag: "🇫🇷", prefix: "fr" },
        'es': { name: "Người TBN", id: "es-ES", flag: "🇪🇸", prefix: "es" },
        'ru': { name: "Người Nga", id: "ru-RU", flag: "🇷🇺", prefix: "ru" },
        'th': { name: "Người Thái", id: "th-TH", flag: "🇹🇭", prefix: "th" },
        'de': { name: "Người Đức", id: "de-DE", flag: "🇩🇪", prefix: "de" }
    };

    document.addEventListener("DOMContentLoaded", () => {
        const langArea = document.getElementById('langButtonsArea');
        Object.keys(langMap).forEach(key => {
            langArea.innerHTML += `
                <div class="col-3">
                    <button class="btn btn-sm btn-white border w-100 shadow-sm py-2" onclick="simulateTourist('${key}')">
                        ${langMap[key].flag} ${langMap[key].name}
                    </button>
                </div>`;
        });
        loadMenu();
    });

    let synthVoices = [];
    window.speechSynthesis.onvoiceschanged = () => { synthVoices = window.speechSynthesis.getVoices(); };

    // SIGNALR KẾT NỐI APP MOBILE
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("http://127.0.0.1:5297/stallHub")
        .withAutomaticReconnect()
        .build();

    connection.on("OnTouristArrived", (incomingId, langCode) => {
        // App thật gửi xuống, tự sinh ID khách ngẫu nhiên để demo
        if (incomingId.toString() === stallId) {
            triggerAppSignal(langCode, null);
        }
    });
    connection.start().catch(err => console.log("SignalR standby"));

    // ==========================================
    // 💡 QUẢN LÝ HÀNG ĐỢI & LOA ĐỌC + DỊCH REAL-TIME API
    // ==========================================
    let isBroadcasting = false;
    let audioQueue = [];
    let ttsTimeout = null;
    let isPlayingTourist = false;

    function toggleBroadcast() {
        if (!isBroadcasting) {
            isBroadcasting = true;
            document.getElementById('broadcastIcon').innerText = "⏸️";
            document.getElementById('broadcastStatus').innerText = "Hệ thống đang bật";
            document.getElementById('broadcastStatus').className = "mt-3 fw-bold text-success";
            playNextTTS();
        } else {
            isBroadcasting = false;
            window.speechSynthesis.cancel();
            clearTimeout(ttsTimeout);
            isPlayingTourist = false;
            document.getElementById('broadcastIcon').innerText = "▶️";
            document.getElementById('broadcastStatus').innerText = "Hệ thống đang tắt";
            document.getElementById('broadcastStatus').className = "mt-3 fw-bold text-secondary";
        }
    }

    async function simulateTourist(langCode) {
        if (!isBroadcasting) return;

        document.getElementById('currentPlayingStatus').innerText = "⏳ Đang dịch thuật bằng AI (Dữ liệu thật)...";

        try {
            // Lấy tiếng Việt từ UI
            let textToRead = document.getElementById('stallTts').value;
            if (!textToRead) textToRead = "Kính chào quý khách";

            // Gọi API dịch mạng thật
            if (langCode !== 'vi') {
                try {
                    const translateRes = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(textToRead)}&langpair=vi|${langCode}`);
                    const translateData = await translateRes.json();

                    if (translateData && translateData.responseData && translateData.responseData.translatedText) {
                        textToRead = translateData.responseData.translatedText;
                    } else {
                        textToRead = mockTranslations[langCode];
                    }
                } catch (apiError) {
                    console.log("Lỗi API Dịch mạng", apiError);
                    textToRead = mockTranslations[langCode];
                }
            }

            audioQueue.push({
                text: textToRead,
                langId: langMap[langCode].id,
                name: langMap[langCode].name,
                prefix: langMap[langCode].prefix
            });
            updateQueueUI();

            if (!isPlayingTourist) {
                window.speechSynthesis.cancel();
                clearTimeout(ttsTimeout);
                playNextTTS();
            }
        } catch (e) { console.error("Lỗi TTS", e); }
    }

    function playNextTTS() {
        if (!isBroadcasting) return;
        clearTimeout(ttsTimeout);

        let item = null;
        if (audioQueue.length > 0) {
            item = audioQueue.shift();
            isPlayingTourist = true;
            updateQueueUI();
        } else {
            isPlayingTourist = false;
            item = {
                text: document.getElementById('stallTts').value || "Kính chào quý khách",
                langId: "vi-VN",
                name: "Tiếng Việt (Lặp lại)",
                prefix: "vi"
            };
        }

        document.getElementById('currentPlayingStatus').innerText = item.name;
        const msg = new SpeechSynthesisUtterance(item.text);
        msg.lang = item.langId;

        if (synthVoices.length > 0) {
            let voice = synthVoices.find(v => v.lang === item.langId && (v.name.includes('Google') || v.name.includes('Microsoft')));
            if (!voice) voice = synthVoices.find(v => v.lang.startsWith(item.prefix));
            if (voice) msg.voice = voice;
        }

        msg.onend = () => {
            if (isBroadcasting) {
                if (audioQueue.length === 0) isPlayingTourist = false;
                ttsTimeout = setTimeout(playNextTTS, 1500);
            }
        };
        window.speechSynthesis.speak(msg);
    }

    function updateQueueUI() {
        const list = document.getElementById('audioQueueList');
        list.innerHTML = audioQueue.map((it, idx) => `<li>${idx + 1}. Khách ${it.name}</li>`).join('');
    }

    // ==========================================
    // 💡 TẠO BÃO KHÁCH & CHỐNG SPAM 2 PHÚT (ĐỒNG BỘ DB)
    // ==========================================
    let recentVisitors = {}; // Lưu dưới dạng: { "MãKhách": ThờiGianVào }

    async function triggerAppSignal(lang, guestId) {
        // 1. Nếu không truyền guestId (Ví dụ tạo Bão khách), tự sinh 1 ID duy nhất
        if (!guestId) {
            guestId = "STORM_" + lang.toUpperCase() + "_" + Math.floor(Math.random() * 1000000);
        }

        // 2. Kiểm tra Cooldown (chống Spam 2 phút = 120,000 ms)
        const now = new Date().getTime();
        if (recentVisitors[guestId] && (now - recentVisitors[guestId] < 120000)) {
            console.log(`⏳ Khách ${guestId} đang ở sạp. Chặn spam Loa và DB!`);
            // Có thể thả Toast nhỏ ở UI để báo cho sếp biết
            let toast = document.createElement("div");
            toast.className = "position-fixed bottom-0 end-0 p-3";
            toast.style.zIndex = 1000;
            toast.innerHTML = `<div class="toast show align-items-center text-bg-warning border-0"><div class="d-flex"><div class="toast-body fw-bold">⏳ Chặn Spam: Khách ${lang} vừa vào sạp!</div></div></div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
            return; // Dừng lập tức, không đọc loa, KHÔNG GỌI API lưu DB
        }

        recentVisitors[guestId] = now;

        // 3. Truyền chính xác guestId xuống API C# để lưu DB
       fetch(`http://127.0.0.1:5297/api/MockData/simulate-tourist/${stallId}/${lang}?deviceId=${guestId}`, { method: 'POST' })
            .then(res => console.log("Đã lưu DB khách:", guestId))
            .catch(e => console.log("Lỗi API lưu DB ngầm"));

        // 4. Cho loa AI đọc
        simulateTourist(lang);
    }

    function simulateStorm() {
        if (!isBroadcasting) {
            alert("⚠️ Vui lòng BẬT LOA (Nút Đỏ) trước khi tạo bão khách!");
            return;
        }

        let countInput = document.getElementById('stormCount').value;
        let count = parseInt(countInput) || 1;

        if (count <= 0) {
            alert("Số lượng khách phải lớn hơn 0!"); return;
        }

        const codes = Object.keys(langMap).filter(c => c !== 'vi');

        for (let i = 0; i < count; i++) {
            const randomLang = codes[Math.floor(Math.random() * codes.length)];
            let delayMs = Math.floor(Math.random() * (count * 800));

            // Không truyền ID -> Hàm triggerAppSignal sẽ tự sinh ID ngẫu nhiên
            setTimeout(() => {
                triggerAppSignal(randomLang, null);
            }, delayMs);
        }
    }

    // ==========================================
    // 💡 QUẢN LÝ LƯU SẠP & MENU
    // ==========================================
    async function updateStallInfo() {
        const btn = document.querySelector('button[onclick="updateStallInfo()"]');
        btn.disabled = true; btn.innerHTML = '⏳ Đang lưu...';

        const formData = new FormData();
        formData.append("Id", stallId);
        formData.append("Name", document.getElementById('stallName').value);
        formData.append("IsOpen", document.getElementById('stallStatus').value === 'true');
        formData.append("TtsScript", document.getElementById('stallTts').value);
        formData.append("OwnerId", document.getElementById('stallOwnerId').value);
        formData.append("RadiusMeter", document.getElementById('stallRadius').value || 50);

        const file = document.getElementById('stallImageFile').files[0];
        if (file) formData.append("ImageFile", file);

        try {
            const res = await fetch(`http://127.0.0.1:5297/api/Stalls/${stallId}`, { method: 'PUT', body: formData });
            if (res.ok) { alert("Lưu sạp thành công!"); window.location.reload(); }
        } catch (e) {} finally { btn.disabled = false; btn.innerHTML = '💾 LƯU THÔNG TIN SẠP'; }
    }

    // ==========================================
        // 💡 QUẢN LÝ LƯU SẠP & MENU (ĐÃ FIX LỖI LƯU ẢNH LÊN DB)
        // ==========================================
        let tempFoods = []; // Danh sách món ăn đang hiển thị

        async function addFood() {
            const btn = document.querySelector('button[onclick="addFood()"]');
            const foodName = document.getElementById('foodName').value.trim();
            const foodPrice = document.getElementById('foodPrice').value;
            const imageInput = document.getElementById('foodImageFile');

            // 1. Kiểm tra đầu vào
            if(!foodName || !foodPrice || !imageInput.files[0]) {
                alert("⚠️ Vui lòng nhập đủ thông tin và chọn ảnh món ăn!");
                return;
            }

            // 2. Chuẩn bị dữ liệu gửi đi (Dùng FormData để gửi File thật)
            const fd = new FormData();
            fd.append("StallId", stallId); // ID của sạp hiện tại
            fd.append("Name", foodName); // Đổi thành Name hoặc NameVi tùy Backend sếp code
            fd.append("BasePrice", foodPrice); // Đổi thành BasePrice cho khớp DB
            fd.append("ImageFile", imageInput.files[0]); // Đính kèm file ảnh thật

            // 3. Khóa nút để chống spam click
            btn.disabled = true;
            btn.innerHTML = '⏳ Đang lưu lên máy chủ...';

            try {
                // 4. GỌI API BACKEND ĐỂ LƯU VÀO DATABASE
                const res = await fetch(`http://127.0.0.1:5297/api/Stalls/add-product`, {
                    method: 'POST',
                    body: fd
                });

                if (res.ok) {
                    // Nếu Backend báo lưu thành công
                    alert("🎉 Đã lưu món ăn mới vào Cơ sở dữ liệu!");

                    // Tải lại danh sách món ăn từ DB để hiển thị ảnh xịn
                    await loadMenu();

                    // Xóa trống form
                    document.getElementById('addMenuForm').reset();
                } else {
                    const errorText = await res.text();
                    alert(`❌ Lỗi từ máy chủ: ${errorText}`);
                }
            }
            catch (e) {
                console.error(e);
                alert("🧨 Không thể kết nối đến Máy chủ API. Vui lòng kiểm tra lại Backend!");
            }
            finally {
                // Mở khóa nút
                btn.disabled = false;
                btn.innerHTML = '➕ LƯU MÓN ĂN';
            }
        }

        async function loadMenu() {
            try {
                const res = await fetch(`http://127.0.0.1:5297/api/Stalls/${stallId}/products`);
                if(res.ok) {
                    const dbFoods = await res.json();
                    tempFoods = dbFoods; // Cập nhật lại list từ dữ liệu thật
                    renderMenu();
                }
            } catch(e) {
                console.error("Lỗi khi tải thực đơn:", e);
            }
        }

        function renderMenu() {
            const container = document.getElementById('foodListContainer');
            document.getElementById('emptyMenuMsg').style.display = tempFoods.length > 0 ? 'none' : 'block';

            container.innerHTML = tempFoods.map(f => `
                <div class="col-md-6 col-lg-6 mb-2">
                    <div class="d-flex align-items-center border p-2 rounded shadow-sm bg-white">
                        <img src="${f.imageUrl ? 'http://127.0.0.1:5297' + f.imageUrl : '/images/default-food.jpg'}"
                             style="width: 70px; height: 70px; object-fit: cover; border-radius: 8px;" class="me-3 border">
                        <div>
                            <h6 class="mb-1 fw-bold text-dark">${f.productName || f.name || 'Món ăn vô danh'}</h6>
                            <span class="text-danger fw-bold fs-6">${parseInt(f.basePrice || f.price || 0).toLocaleString('vi-VN')} VNĐ</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }
</script>