<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark">🍱 Thực đơn món ăn</h3>
        <button class="btn btn-primary rounded-pill px-4 shadow">+ Thêm món mới</button>
    </div>

    <div class="row">
        @foreach (var p in Model.Products)
        {
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <img src="http://localhost:5297/images/@p.ImageUrl" class="card-img-top" style="height:150px; object-fit:cover;">
                    <div class="card-body">
                        <h6 class="fw-bold mb-1">@p.ProductName</h6>
                        <p class="text-danger small fw-bold mb-3">@p.BasePrice.ToString("N0") VNĐ</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary w-100 rounded-pill">Sửa</button>
                            <button class="btn btn-sm btn-outline-danger w-100 rounded-pill" onclick="deleteProduct(@p.Id)">Xóa</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>