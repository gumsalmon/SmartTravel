<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- ═══ TROPICAL SUNRISE PALETTE ═══ -->
    <!-- Primary: Vibrant Coral-Orange — energy, appetite, warmth -->
    <Color x:Key="Primary">#FF5722</Color>
    <Color x:Key="PrimaryDark">#FF7043</Color>
    <Color x:Key="PrimaryLight">#FF8A65</Color>
    <Color x:Key="PrimaryDarkText">#1A0A00</Color>

    <!-- Accent: Sunny Amber — joy, enthusiasm -->
    <Color x:Key="Secondary">#FFB300</Color>
    <Color x:Key="SecondaryLight">#FFE082</Color>
    <Color x:Key="SecondaryDarkText">#FF6F00</Color>

    <!-- Highlight: Fresh Teal — trustworthy, refreshing -->
    <Color x:Key="Tertiary">#00BCD4</Color>
    <Color x:Key="TertiaryLight">#B2EBF2</Color>

    <!-- Backgrounds (Light Mode) -->
    <Color x:Key="PageBackground">#FFF8F5</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBackgroundAlt">#FFF3EE</Color>
    <Color x:Key="SectionBackground">#FFF1E6</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A0A00</Color>
    <Color x:Key="TextSecondary">#6D4C41</Color>
    <Color x:Key="TextMuted">#A07060</Color>

    <!-- Status Colors -->
    <Color x:Key="Success">#43A047</Color>
    <Color x:Key="Warning">#FFB300</Color>
    <Color x:Key="Error">#E53935</Color>
    <Color x:Key="Info">#039BE5</Color>

    <!-- Neutrals -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#1A0A00</Color>
    <Color x:Key="MidnightBlue">#1A0A00</Color>
    <Color x:Key="Magenta">#FF5722</Color>

    <Color x:Key="Gray100">#FBE9E7</Color>
    <Color x:Key="Gray200">#FFCCBC</Color>
    <Color x:Key="Gray300">#FFAB91</Color>
    <Color x:Key="Gray400">#A07060</Color>
    <Color x:Key="Gray500">#795548</Color>
    <Color x:Key="Gray600">#4E342E</Color>
    <Color x:Key="Gray900">#3E2723</Color>
    <Color x:Key="Gray950">#1A0A00</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>