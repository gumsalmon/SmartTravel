<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HeriStep.Client.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HeriStep.Client"
    xmlns:views="clr-namespace:HeriStep.Client.Views"
    Title="HeriStep - Du Lịch Thông Minh"
    TabBarBackgroundColor="#E6FAFA"
    TabBarUnselectedColor="#5A969E"
    TabBarTitleColor="#045950"
    FlyoutBehavior="Disabled">


    <TabBar>
        <Tab Title="Trang chủ">
            <ShellContent
                Title="Trang chủ"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Voice Aura">
            <ShellContent
                Title="Voice Aura"
                ContentTemplate="{DataTemplate views:VoiceAuraPage}"
                Route="VoiceAuraPage" />
        </Tab>

        <Tab Title="Quét QR">
            <ShellContent
                Title="Quét QR"
                ContentTemplate="{DataTemplate views:ScannerPage}"
                Route="ScannerPage" />
        </Tab>

        <Tab Title="Cá nhân">
            <ShellContent
                Title="Cá nhân"
                ContentTemplate="{DataTemplate views:ProfilePage}"
                Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>