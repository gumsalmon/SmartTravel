<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HeriStep.Client.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HeriStep.Client"
    xmlns:views="clr-namespace:HeriStep.Client.Views"
    Title="HeriStep - Du Lịch Thông Minh"
    TabBarBackgroundColor="#E6FAFA"
    TabBarUnselectedColor="#5A969E"
    TabBarTitleColor="#045950"
    FlyoutBehavior="Disabled">


    <TabBar>
        <Tab Title="Explore">
            <Tab.Icon>
                <FontImageSource Glyph="🧭" Color="#045950" />
            </Tab.Icon>
            <ShellContent
                Title="Explore"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Aura">
            <Tab.Icon>
                <FontImageSource Glyph="ılı" Color="#045950" />
            </Tab.Icon>
            <ShellContent
                Title="Aura"
                ContentTemplate="{DataTemplate views:VoiceAuraPage}"
                Route="VoiceAuraPage" />
        </Tab>

        <Tab Title="Scanner">
            <Tab.Icon>
                <FontImageSource Glyph="🔳" Color="#045950" />
            </Tab.Icon>
            <ShellContent
                Title="Scanner"
                ContentTemplate="{DataTemplate views:ScannerPage}"
                Route="ScannerPage" />
        </Tab>

        <Tab Title="Profile">
            <Tab.Icon>
                <FontImageSource Glyph="👤" Color="#045950" />
            </Tab.Icon>
            <ShellContent
                Title="Profile"
                ContentTemplate="{DataTemplate views:ProfilePage}"
                Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>