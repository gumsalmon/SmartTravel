<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HeriStep.Client.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HeriStep.Client"
    xmlns:views="clr-namespace:HeriStep.Client.Views"
    Title="HeriStep - Du Lịch Thông Minh">

    <TabBar>

        <Tab Title="Bản đồ" Icon="dotnet_bot.svg">
            <ShellContent
                Title="Bản đồ"
                ContentTemplate="{DataTemplate views:HomePage}"
                Route="HomePage" />
        </Tab>

        <Tab Title="Cửa hàng" Icon="dotnet_bot.svg">
            <ShellContent
                Title="Cửa hàng"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

    </TabBar>

</Shell>