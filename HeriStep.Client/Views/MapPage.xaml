<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="HeriStep.Client.Views.MapPage"
             Title="Bản Đồ Vĩnh Khánh">

    <Grid>

        <mapsui:MapView x:Name="mapView" VerticalOptions="Fill" HorizontalOptions="Fill" />
        <BoxView x:Name="overlay" BackgroundColor="Black" Opacity="0.3" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="ClosePopup_Clicked" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border x:Name="shopPopup" IsVisible="False" VerticalOptions="End" Margin="15,0,15,30"
                StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Padding="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.2"/>
            </Border.Shadow>

            <Grid RowDefinitions="140, Auto" ColumnDefinitions="*">
                <Image x:Name="popupImage" Source="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&amp;w=2070&amp;auto=format&amp;fit=crop" 
                       Aspect="AspectFill" Grid.Row="0" BackgroundColor="#E0E0E0"/>

                <Button Text="✕" FontAttributes="Bold" TextColor="Black" BackgroundColor="White" 
                        CornerRadius="15" WidthRequest="30" HeightRequest="30" Padding="0"
                        HorizontalOptions="End" VerticalOptions="Start" Margin="10"
                        Clicked="ClosePopup_Clicked" Opacity="0.8"/>

                <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="8">
                    <Label x:Name="popupName" Text="Tên quán ốc" FontSize="18" FontAttributes="Bold" TextColor="Black"/>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⭐ 4.8 (120+ đánh giá)" FontSize="13" TextColor="#FFA000" FontAttributes="Bold"/>
                        <Label Text="• Phố Ẩm Thực Vĩnh Khánh" FontSize="13" TextColor="Gray"/>
                    </HorizontalStackLayout>

                    <Button x:Name="btnViewDetail" Text="Xem Chi Tiết Quán" BackgroundColor="#1A73E8" TextColor="White" 
        FontAttributes="Bold" CornerRadius="10" HeightRequest="45" Margin="0,10,0,0"
        Clicked="btnViewDetail_Clicked" />
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>