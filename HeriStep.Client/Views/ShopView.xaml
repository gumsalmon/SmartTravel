<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:HeriStep.Shared;assembly=HeriStep.Shared"
             x:Class="HeriStep.Client.Views.ShopView">

    <VerticalStackLayout Spacing="10" Padding="15">
        <Label Text="📍 Cửa hàng gần bạn" 
               FontSize="20" 
               FontAttributes="Bold" 
               TextColor="#2B2B2B" />

        <CollectionView ItemsSource="{Binding Points}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Đang tải dữ liệu từ 10.0.2.2..." 
                       HorizontalOptions="Center" 
                       Margin="20" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Stall">
                    <Frame Margin="0,8" 
                           Padding="12" 
                           HasShadow="True" 
                           CornerRadius="15" 
                           BorderColor="#E0E0E0">

                        <HorizontalStackLayout Spacing="15">
                            <Border StrokeShape="RoundRectangle 10"
                                    HeightRequest="85"
                                    WidthRequest="85"
                                    StrokeThickness="0">
                                <Image Source="{Binding imageUrl}" 
                                       Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding name}" 
                                       FontSize="17" 
                                       FontAttributes="Bold" 
                                       TextColor="Black" />

                                <Label Text="{Binding tourId, StringFormat='Thuộc chuyến tham quan số: {0}'}" 
                                       FontSize="13" 
                                       TextColor="#757575" />

                                <HorizontalStackLayout Spacing="5" IsVisible="{Binding isOpen}">
                                    <Label Text="●" TextColor="#27AE60" FontSize="12" VerticalOptions="Center"/>
                                    <Label Text="Đang hoạt động" 
                                           FontSize="12" 
                                           TextColor="#27AE60" 
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>