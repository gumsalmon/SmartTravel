<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.LanguageSelectionPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">
             
    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Fill">
        
        <Image Source="splash.png" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" Margin="0,0,0,20"/>
        
        <Label Text="Welcome / Chào mừng" FontSize="26" FontAttributes="Bold" TextColor="#FF8C00" HorizontalOptions="Center" />
        <Label Text="Please select your language / Vui lòng chọn ngôn ngữ" FontSize="14" TextColor="#B0A090" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,20"/>

        <CollectionView x:Name="languageCollection"
                        ItemsSource="{Binding Languages}"
                        SelectionMode="Single"
                        SelectionChanged="OnLanguageSelected"
                        VerticalOptions="FillAndExpand"
                        HeightRequest="420">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#FF8C00" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#1C1C1C" Padding="14" Margin="0,0,0,10">
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="{Binding Flag}" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="{Binding LangName}" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
    </VerticalStackLayout>
</ContentPage>
