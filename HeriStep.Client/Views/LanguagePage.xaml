<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.LanguagePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C1C1C">
    <Grid RowDefinitions="Auto,*,Auto" Padding="20,50,20,30">
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="HeriStep" FontSize="36" FontAttributes="Bold" TextColor="#FDF5E6" HorizontalTextAlignment="Center"/>
            <Label Text="Select language" FontSize="16" TextColor="#D35400" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="languageCollection"
                        ItemsSource="{Binding Languages}"
                        SelectionMode="Single"
                        SelectionChanged="OnLanguageSelected"
                        Margin="0,20,0,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="#D35400"
                            BackgroundColor="#2A2A2A"
                            Padding="14">
                        <Label Text="{Binding LangName}" TextColor="#FDF5E6" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                x:Name="btnGetStarted"
                Text="GET STARTED"
                IsEnabled="False"
                Opacity="0.45"
                HeightRequest="52"
                CornerRadius="24"
                BackgroundColor="#D35400"
                TextColor="#FDF5E6"
                Clicked="OnGetStartedClicked"/>
    </Grid>
</ContentPage>
