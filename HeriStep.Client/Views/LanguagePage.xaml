<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.LanguagePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C1C1C">

    <!-- Root Grid: full-page layered layout -->
    <Grid>

        <!-- ── LAYER 1: Background food image (faded) ── -->
        <Image Source="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&amp;w=800"
               Aspect="AspectFill" Opacity="0.22" VerticalOptions="Fill" HorizontalOptions="Fill"/>

        <!-- ── LAYER 2: Dark gradient overlay ── -->
        <BoxView VerticalOptions="Fill" HorizontalOptions="Fill">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F01C1C1C" Offset="0.0"/>
                    <GradientStop Color="#881C1C1C" Offset="0.4"/>
                    <GradientStop Color="#FF1C1C1C" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- ── LAYER 3: Content ── -->
        <Grid RowDefinitions="Auto, *, Auto" Padding="0,55,0,40">

            <!-- ══ HEADER ══ -->
            <VerticalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center" Padding="30,0">
                <!-- Logo / App name -->
                <Label Text="HeriStep" FontSize="40" FontAttributes="Bold" TextColor="#FDF5E6"
                       HorizontalTextAlignment="Center" CharacterSpacing="1"/>
                <Label Text="A DIGITAL GASTRONOME JOURNEY" FontSize="10" TextColor="#B0A090"
                       HorizontalTextAlignment="Center" CharacterSpacing="3" FontAttributes="Bold"/>

                <BoxView HeightRequest="1" BackgroundColor="#30FFFFFF" Margin="20,14,20,14"/>

                <!-- Section title -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="Select " FontSize="26" FontAttributes="Bold" TextColor="#FDF5E6"/>
                    <Label Text="Language" FontSize="26" FontAttributes="Bold" TextColor="#D35400"/>
                </HorizontalStackLayout>
                <Label Text="To begin your culinary exploration" FontSize="14" TextColor="#B0A090"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- ══ LANGUAGE GRID (glassmorphism cards) ══ -->
            <ScrollView Grid.Row="1" Margin="20,24,20,10" VerticalScrollBarVisibility="Never">
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="14" ColumnSpacing="14">

                    <!-- ── Vietnamese ── -->
                    <Border x:Name="cardVI" Grid.Row="0" Grid.Column="0"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="vi"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇻🇳" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="VIETNAM" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── English ── -->
                    <Border x:Name="cardEN" Grid.Row="0" Grid.Column="1"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="en"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇬🇧" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="UK" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Japanese ── -->
                    <Border x:Name="cardJA" Grid.Row="1" Grid.Column="0"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="ja"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇯🇵" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="JAPAN" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Korean ── -->
                    <Border x:Name="cardKO" Grid.Row="1" Grid.Column="1"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="ko"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇰🇷" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="KOREA" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── French ── -->
                    <Border x:Name="cardFR" Grid.Row="2" Grid.Column="0"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="fr"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇫🇷" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="FRANCE" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── German ── -->
                    <Border x:Name="cardDE" Grid.Row="2" Grid.Column="1"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="de"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇩🇪" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="GERMANY" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Chinese ── -->
                    <Border x:Name="cardZH" Grid.Row="3" Grid.Column="0"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="zh"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇨🇳" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="CHINA" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Spanish ── -->
                    <Border x:Name="cardES" Grid.Row="3" Grid.Column="1"
                            StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#40FFFFFF"
                            BackgroundColor="#CC2A2A2A" Padding="0,22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="es"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="#40FFFFFF"
                                    HeightRequest="56" WidthRequest="56" Padding="0" HorizontalOptions="Center">
                                <Label Text="🇪🇸" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="SPAIN" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6"
                                   HorizontalOptions="Center" CharacterSpacing="1"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </ScrollView>

            <!-- ══ FOOTER: GET STARTED button ══ -->
            <VerticalStackLayout Grid.Row="2" Padding="24,0" Spacing="14">
                <!-- The amber CTA button — disabled until a language is selected -->
                <Button x:Name="btnGetStarted"
                        Text="GET STARTED"
                        CornerRadius="28"
                        BackgroundColor="#D35400"
                        TextColor="#FDF5E6"
                        FontAttributes="Bold"
                        FontSize="17"
                        CharacterSpacing="1.5"
                        HeightRequest="56"
                        IsEnabled="False"
                        Opacity="0.45"
                        Clicked="OnGetStartedClicked">
                    <Button.Shadow>
                        <Shadow Brush="#D35400" Offset="0,6" Radius="18" Opacity="0.5"/>
                    </Button.Shadow>
                </Button>
                <Label Text="You can change this anytime in Settings"
                       FontSize="11" TextColor="#6B5B4E"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
