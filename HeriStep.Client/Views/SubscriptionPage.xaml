<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.SubscriptionPage"
             x:Name="pageRoot"
             Title="Đăng ký gói cước"
             BackgroundColor="#FFF8F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" HorizontalOptions="Center" VerticalOptions="Start">
            <Image Source="splash.png" WidthRequest="150" HeightRequest="150" HorizontalOptions="Center" />
            <Label Text="HeriStep SmartTravel" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#FF5722" />
            <Label x:Name="lblDescription" Text="Thiết bị của bạn chưa được kích hoạt hoặc đã hết hạn. Vui lòng chọn gói cước bên dưới để tiếp tục sử dụng."
                   HorizontalTextAlignment="Center" TextColor="#6D4C41" FontFamily="OpenSansRegular" />

            <!-- Device ID -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label x:Name="lblDevicePrefix" Text="Mã thiết bị:" TextColor="#A07060" FontFamily="OpenSansRegular" />
                <Label x:Name="lblDeviceId" Text="..." FontAttributes="Bold" TextColor="#1A0A00" />
            </HorizontalStackLayout>

            <!-- Packages -->
            <VerticalStackLayout x:Name="vlPackages" Spacing="10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#FFCCBC" StrokeThickness="1.5" BackgroundColor="White" Padding="15" Margin="0,5">
                            <Border.Shadow>
                                <Shadow Brush="#FF5722" Offset="0,3" Radius="8" Opacity="0.08"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPackageTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="{Binding PackageName}" FontAttributes="Bold" FontSize="16" TextColor="#1A0A00" FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding DurationText}" TextColor="#A07060" FontSize="12" FontFamily="OpenSansRegular" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="{Binding PriceText}"
                                           TextColor="#FF5722" FontAttributes="Bold" FontSize="16" HorizontalOptions="End" />
                                    <Label Text="{Binding ActionText}" TextColor="#FFB300" FontSize="11"
                                           HorizontalOptions="End" FontFamily="OpenSansRegular"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Payment Layer -->
            <VerticalStackLayout x:Name="vlPayment" IsVisible="False" Spacing="15" HorizontalOptions="Center">
                <Label x:Name="lblQrTitle" Text="Quét mã QR dưới đây để thanh toán:" HorizontalOptions="Center" TextColor="#1A0A00" FontFamily="OpenSansRegular" />
                
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="2" Stroke="#FF5722"
                        Padding="10" HorizontalOptions="Center" BackgroundColor="White">
                    <Image x:Name="imgQrCode" WidthRequest="220" HeightRequest="220" HorizontalOptions="Center" />
                </Border>
                
                <Label x:Name="lblPaymentAmount" TextColor="#FF5722" FontAttributes="Bold" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblQrNote" Text="Nội dung/mã lệnh nạp tiền đã được nhập sẵn!" FontSize="12" TextColor="#FFB300" HorizontalOptions="Center" FontFamily="OpenSansRegular" />

                <ActivityIndicator x:Name="aiPolling" IsRunning="True" Color="#FF5722" HorizontalOptions="Center" Margin="0,10,0,0" />
                <Label x:Name="lblWait" Text="Đang chờ nhận tiền tít tít..." TextColor="#A07060" HorizontalOptions="Center" FontSize="14" FontFamily="OpenSansItalic" />

                <Button x:Name="btnCancel" Text="Trở lại chọn gói" BackgroundColor="Transparent" TextColor="#A07060" Clicked="OnCancelPayment" FontFamily="OpenSansRegular" Margin="0,10,0,0"/>
            </VerticalStackLayout>

            <!-- DEV BYPASS -->
            <Button x:Name="btnBypass" Text="DEV: Vào thẳng app" FontAttributes="Bold"
                    BackgroundColor="#FFE0D6" TextColor="#FF5722"
                    Clicked="OnBypassClicked" Margin="0,20,0,0" CornerRadius="12" HeightRequest="44"/>
                    
            <BoxView HeightRequest="20" BackgroundColor="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
