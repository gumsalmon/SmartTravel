<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.ShopDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#E5F8FA">

    <ScrollView>
        <VerticalStackLayout>
            
            <!-- Hero Banner -->
            <Grid HeightRequest="380">
                <Image x:Name="heroImage" Source="https://images.unsplash.com/photo-1565557623262-b51c2513a641?q=80&amp;w=800" Aspect="AspectFill"/>
                
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#99000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="0.3"/>
                            <GradientStop Color="#00000000" Offset="0.5"/>
                            <GradientStop Color="#E5F8FA" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Status Bar Icons -->
                <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,40,20,0" VerticalOptions="Start">
                    <Button Text="☰" FontSize="20" TextColor="White" BackgroundColor="Transparent" Padding="0" Margin="0" Grid.Column="0" Clicked="OnBackButtonClicked"/>
                    <Label Text="Vinh Khanh Guide" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1"/>
                    <Label Text="A文" FontSize="18" TextColor="White" VerticalOptions="Center" Grid.Column="2"/>
                </Grid>

                <VerticalStackLayout VerticalOptions="End" Padding="20" Spacing="5">
                    <Label Text="Signature" FontSize="36" FontAttributes="Italic" TextColor="#F3DCA9" Margin="0,0,0,-10"/>
                    <Label Text="GRILLED SEAFOOD WORK" FontSize="12" FontAttributes="Bold" TextColor="#F3DCA9" CharacterSpacing="1"/>

                    <Frame CornerRadius="8" BackgroundColor="#E65100" Padding="8,4" HasShadow="False" BorderColor="Transparent" HorizontalOptions="Start" Margin="0,15,0,0">
                        <Label Text="DISTRICT 4 HIDDEN GEM" FontSize="9" FontAttributes="Bold" TextColor="White"/>
                    </Frame>

                    <Label x:Name="shopName" Text="Oc Oanh Vinh&#10;Khanh" FontSize="32" FontAttributes="Bold" TextColor="White" LineHeight="1.1"/>
                    
                    <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                        <HorizontalStackLayout Spacing="6" Grid.Column="0" VerticalOptions="Center">
                            <Label Text="📍" FontSize="12" TextColor="White"/>
                            <Label Text="534 Vinh Khanh, Ward 10" FontSize="11" TextColor="White"/>
                        </HorizontalStackLayout>
                        <Frame CornerRadius="18" BackgroundColor="#00695C" Padding="15,8" HasShadow="False" BorderColor="Transparent" Grid.Column="1">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="Aura AI Guide" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="🗣" FontSize="14" VerticalOptions="Center" TextColor="White"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="20,10,20,40" Spacing="25">
                
                <!-- Menu Intro -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Signature Menu" FontSize="20" FontAttributes="Bold" TextColor="#004D40"/>
                    <Label Text="Curated flavors from Saigon's most vibrant street food artery. Multilingual descriptions powered by Aura." FontSize="13" TextColor="#00695C" LineHeight="1.4"/>
                </VerticalStackLayout>

                <!-- Dish 1 -->
                <Frame CornerRadius="24" BackgroundColor="White" Padding="0" IsClippedToBounds="True" BorderColor="Transparent" HasShadow="False">
                    <VerticalStackLayout>
                        <Image Source="https://images.unsplash.com/photo-1548690312-e3b507d8c110?q=80&amp;w=600" HeightRequest="150" Aspect="AspectFill"/>
                        <VerticalStackLayout Padding="20" Spacing="10">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Oc Huong Rang&#10;Muoi" FontSize="18" FontAttributes="Bold" TextColor="#004D40" Grid.Column="0" LineHeight="1.1"/>
                                <Label Text="185k" FontSize="16" FontAttributes="Bold" TextColor="#C62828" Grid.Column="1" VerticalOptions="Start"/>
                            </Grid>
                            <Label Text="Spotted Babylon snails roasted with chili salt. A perfect balance of sea sweetness and spicy crust." FontSize="12" TextColor="#5A969E" LineHeight="1.4"/>
                            <HorizontalStackLayout Spacing="8">
                                <Frame CornerRadius="10" BackgroundColor="#E0F7FA" Padding="10,4" HasShadow="False" BorderColor="Transparent">
                                    <Label Text="MUST TRY" FontSize="9" FontAttributes="Bold" TextColor="#00695C"/>
                                </Frame>
                                <Frame CornerRadius="10" BackgroundColor="#E0F7FA" Padding="10,4" HasShadow="False" BorderColor="Transparent">
                                    <Label Text="SPICY" FontSize="9" FontAttributes="Bold" TextColor="#00695C"/>
                                </Frame>
                            </HorizontalStackLayout>
                            
                            <Button Text="🛒  Add to Order" CornerRadius="20" BackgroundColor="#80CBC4" TextColor="#004D40" FontAttributes="Bold" HeightRequest="40" Margin="0,10,0,0"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Dish 2 -->
                <Frame CornerRadius="24" BackgroundColor="White" Padding="0" IsClippedToBounds="True" BorderColor="Transparent" HasShadow="False">
                    <VerticalStackLayout>
                        <Grid>
                            <Image Source="https://images.unsplash.com/photo-1551187126-1070e17631cc?q=80&amp;w=600" HeightRequest="120" Aspect="AspectFill"/>
                            <Frame CornerRadius="12" BackgroundColor="White" Padding="8,4" HasShadow="False" HorizontalOptions="End" VerticalOptions="Start" Margin="15" BorderColor="Transparent">
                                <Label Text="65k" TextColor="#C62828" FontSize="11" FontAttributes="Bold"/>
                            </Frame>
                        </Grid>
                        <VerticalStackLayout Padding="15" Spacing="5">
                            <Label Text="Rau Muong Xao Toi" FontSize="16" FontAttributes="Bold" TextColor="#004D40"/>
                            <Label Text="Water spinach flash-fried with aromatic garlic." FontSize="12" TextColor="#5A969E" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Dish 3 -->
                <Frame CornerRadius="24" BackgroundColor="White" Padding="0" IsClippedToBounds="True" BorderColor="Transparent" HasShadow="False">
                    <VerticalStackLayout>
                        <Grid>
                            <Image Source="https://images.unsplash.com/photo-1565557623262-b51c2513a641?q=80&amp;w=600" HeightRequest="120" Aspect="AspectFill"/>
                            <Frame CornerRadius="12" BackgroundColor="White" Padding="8,4" HasShadow="False" HorizontalOptions="End" VerticalOptions="Start" Margin="15" BorderColor="Transparent">
                                <Label Text="210k" TextColor="#C62828" FontSize="11" FontAttributes="Bold"/>
                            </Frame>
                        </Grid>
                        <VerticalStackLayout Padding="15" Spacing="5">
                            <Label Text="Tom Nuong Muoi Ot" FontSize="16" FontAttributes="Bold" TextColor="#004D40"/>
                            <Label Text="Tiger prawns grilled with spicy house-made chili salt." FontSize="12" TextColor="#5A969E" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Voice Aura Banner -->
                <Frame CornerRadius="24" Padding="25" BorderColor="Transparent" HasShadow="False">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00695C" Offset="0"/>
                            <GradientStop Color="#004D40" Offset="1"/>
                        </LinearGradientBrush>
                    </Frame.Background>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="✨" FontSize="20" TextColor="#80CBC4"/>
                        <Label Text="Voice Aura is Active" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="Scan any dish name to hear the story, ingredients, and flavor profile in your preferred language." FontSize="13" TextColor="#B2DFDB" LineHeight="1.4"/>
                        
                        <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                            <Button Text="EN" CornerRadius="20" BackgroundColor="Transparent" BorderColor="White" BorderWidth="1" TextColor="White" FontAttributes="Bold" HeightRequest="40" WidthRequest="40" Padding="0"/>
                            <Button Text="VN" CornerRadius="20" BackgroundColor="Transparent" BorderColor="#4DFFFFFF" BorderWidth="1" TextColor="#4DFFFFFF" FontAttributes="Bold" HeightRequest="40" WidthRequest="40" Padding="0"/>
                            <Button Text="KR" CornerRadius="20" BackgroundColor="Transparent" BorderColor="#4DFFFFFF" BorderWidth="1" TextColor="#4DFFFFFF" FontAttributes="Bold" HeightRequest="40" WidthRequest="40" Padding="0"/>
                            <Button Text="JP" CornerRadius="20" BackgroundColor="Transparent" BorderColor="#4DFFFFFF" BorderWidth="1" TextColor="#4DFFFFFF" FontAttributes="Bold" HeightRequest="40" WidthRequest="40" Padding="0"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>