<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C1C1C">

    <ScrollView>
        <VerticalStackLayout Padding="20,50,20,30" Spacing="18">

            <!-- ══ HEADER ══ -->
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Text="←" FontSize="18" TextColor="#D35400" BackgroundColor="Transparent"
                        Padding="0" Grid.Column="0" Clicked="OnHomeClicked"/>
                <Label x:Name="lblProfileTitle" Text="Profile" FontSize="18" FontAttributes="Bold"
                       TextColor="#FDF5E6" HorizontalOptions="Center" VerticalOptions="Center"
                       Grid.Column="1"/>
                <Border StrokeShape="RoundRectangle 20" HeightRequest="40" WidthRequest="40"
                        StrokeThickness="2" Stroke="#D35400" Grid.Column="2">
                    <Image Source="https://images.unsplash.com/photo-1599566150163-29194dcaad36?q=80&amp;w=200"
                           Aspect="AspectFill"/>
                </Border>
            </Grid>

            <!-- ══ AVATAR + NAME ══ -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,10,0,0">
                <Border StrokeShape="RoundRectangle 55" HeightRequest="100" WidthRequest="100"
                        StrokeThickness="3" Stroke="#D35400" HorizontalOptions="Center">
                    <Image Source="https://images.unsplash.com/photo-1599566150163-29194dcaad36?q=80&amp;w=300"
                           Aspect="AspectFill"/>
                </Border>
                <Label Text="Khách Du Lịch" FontSize="24" FontAttributes="Bold"
                       TextColor="#FDF5E6" HorizontalOptions="Center" Margin="0,8,0,0"/>
                <Label x:Name="lblDeviceId" Text="Mã máy: Đang tải..." FontSize="13" TextColor="#6B5B4E" HorizontalOptions="Center"/>
                <Label x:Name="lblTimeRemaining" Text="Hạn sử dụng: Đang kiểm tra..." FontSize="13" FontAttributes="Bold" TextColor="#FFBF00" HorizontalOptions="Center" Margin="0,5,0,0"/>
                
                <!-- Amber accent strip -->
                <BoxView HeightRequest="3" WidthRequest="50" CornerRadius="2"
                         Color="#D35400" HorizontalOptions="Center" Margin="0,6,0,0"/>
            </VerticalStackLayout>

            <!-- ══ STATS ROW ══ -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="14,16" StrokeThickness="0" Grid.Column="0" HorizontalOptions="Fill">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="49" FontSize="22" FontAttributes="Bold" TextColor="#D35400"
                               HorizontalOptions="Center"/>
                        <Label x:Name="lblStatVisited" Text="Visited" FontSize="10" TextColor="#6B5B4E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="14,16" StrokeThickness="0" Grid.Column="1" HorizontalOptions="Fill">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="12" FontSize="22" FontAttributes="Bold" TextColor="#FFBF00"
                               HorizontalOptions="Center"/>
                        <Label x:Name="lblStatSaved" Text="Saved" FontSize="10" TextColor="#6B5B4E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="14,16" StrokeThickness="0" Grid.Column="2" HorizontalOptions="Fill">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="★ 4.8" FontSize="20" FontAttributes="Bold" TextColor="#D35400"
                               HorizontalOptions="Center"/>
                        <Label x:Name="lblStatRating" Text="Rating" FontSize="10" TextColor="#6B5B4E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ══ CHANGE LANGUAGE ══ -->
            <Border StrokeShape="RoundRectangle 20" BackgroundColor="#242424"
                    Padding="18,16" StrokeThickness="1" Stroke="#3D1A00">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangeLanguageTapped"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Border StrokeShape="RoundRectangle 14" HeightRequest="44" WidthRequest="44"
                            BackgroundColor="#3D1A00" Padding="0" StrokeThickness="0" Grid.Column="0">
                        <Label Text="🌐" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="14,0" Spacing="2">
                        <Label x:Name="lblChangeLang" Text="Change Language" FontSize="15" FontAttributes="Bold" TextColor="#FDF5E6"/>
                        <Label x:Name="lblChangeLangDesc" Text="Tap to switch app language" FontSize="12" TextColor="#6B5B4E"/>
                    </VerticalStackLayout>
                    <Label Text="›" FontSize="24" TextColor="#D35400" Grid.Column="2" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ══ QUICK ACTIONS ══ -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <!-- Saved Spots -->
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="15" StrokeThickness="0" Grid.Column="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSavedSpotsTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="12">
                        <Border StrokeShape="RoundRectangle 14" HeightRequest="40" WidthRequest="40"
                                BackgroundColor="#3D1A00" Padding="0" StrokeThickness="0">
                            <Label Text="🔖" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="lblSaved" Text="Saved" FontSize="14" FontAttributes="Bold" TextColor="#FDF5E6"/>
                            <Label x:Name="lblSavedCount" Text="12 places" FontSize="11" TextColor="#6B5B4E"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
                <!-- Support -->
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="15" StrokeThickness="0" Grid.Column="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSupportTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="12">
                        <Border StrokeShape="RoundRectangle 14" HeightRequest="40" WidthRequest="40"
                                BackgroundColor="#3D1A00" Padding="0" StrokeThickness="0">
                            <Label Text="🎧" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="lblSupport" Text="Support" FontSize="14" FontAttributes="Bold" TextColor="#FDF5E6"/>
                            <Label x:Name="lblSupportDesc" Text="24/7 Help" FontSize="11" TextColor="#6B5B4E"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- ══ CHANGE PACKAGE / LOGOUT ══ -->
            <Border StrokeShape="RoundRectangle 20" BackgroundColor="#4A1515"
                    Padding="18,16" StrokeThickness="1" Stroke="#FF4444" Margin="0,10,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangePackageTapped"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Border StrokeShape="RoundRectangle 14" HeightRequest="44" WidthRequest="44"
                            BackgroundColor="#2D0A0A" Padding="0" StrokeThickness="0" Grid.Column="0">
                        <Label Text="🔄" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="14,0" Spacing="2">
                        <Label x:Name="lblChangePkg" Text="Thay đổi gói cước" FontSize="15" FontAttributes="Bold" TextColor="#FFCCCC"/>
                        <Label x:Name="lblChangePkgDesc" Text="Chuyển sang màn hình chọn gói" FontSize="12" TextColor="#AA7777"/>
                    </VerticalStackLayout>
                    <Label Text="›" FontSize="24" TextColor="#FF4444" Grid.Column="2" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ══ RECENT HISTORY ══ -->
            <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*, Auto">
                    <Label x:Name="lblRecentHistory" Text="Recent History" FontSize="20" FontAttributes="Bold"
                           TextColor="#FDF5E6" Grid.Column="0"/>
                    <Label x:Name="lblViewAll" Text="View All" FontSize="13" FontAttributes="Bold"
                           TextColor="#D35400" Grid.Column="1" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewAllHistoryTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- History 1 -->
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="14" StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHistoryItem1Tapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="56, *, Auto" ColumnSpacing="14">
                        <Image Source="https://images.unsplash.com/photo-1544025162-8e658402afb0?w=200"
                               Aspect="AspectFill" HeightRequest="56" WidthRequest="56" Grid.Column="0">
                            <Image.Clip>
                                <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                            </Image.Clip>
                        </Image>
                        <VerticalStackLayout VerticalOptions="Center" Grid.Column="1" Spacing="3">
                            <Label Text="Oc Dao Vinh Khanh" FontSize="14" FontAttributes="Bold" TextColor="#FDF5E6"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="★ 4.8" FontSize="11" TextColor="#D35400" FontAttributes="Bold"/>
                                <Label Text="·" FontSize="11" TextColor="#3A3A3A"/>
                                <Label Text="Seafood · Snails" FontSize="11" TextColor="#6B5B4E"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Text="›" FontSize="22" TextColor="#D35400" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- History 2 -->
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#242424"
                        Padding="14" StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHistoryItem2Tapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="56, *, Auto" ColumnSpacing="14">
                        <Image Source="https://images.unsplash.com/photo-1574484284002-952d92456975?w=200"
                               Aspect="AspectFill" HeightRequest="56" WidthRequest="56" Grid.Column="0">
                            <Image.Clip>
                                <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                            </Image.Clip>
                        </Image>
                        <VerticalStackLayout VerticalOptions="Center" Grid.Column="1" Spacing="3">
                            <Label Text="Mrs. Sau's Rolls" FontSize="14" FontAttributes="Bold" TextColor="#FDF5E6"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="★ 4.5" FontSize="11" TextColor="#D35400" FontAttributes="Bold"/>
                                <Label Text="·" FontSize="11" TextColor="#3A3A3A"/>
                                <Label Text="Traditional Appetizers" FontSize="11" TextColor="#6B5B4E"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Text="›" FontSize="22" TextColor="#D35400" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
