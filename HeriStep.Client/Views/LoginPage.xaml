<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30, 60, 30, 30">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,20">
                <Frame HeightRequest="100" WidthRequest="100" CornerRadius="50" BackgroundColor="#FCE4EC" HasShadow="False" HorizontalOptions="Center">
                    <Label Text="🐙" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                <Label Text="HeriStep" FontSize="32" FontAttributes="Bold" TextColor="#212121" HorizontalOptions="Center" />
                <Label Text="Discover Vinh Khanh Food Street" FontSize="16" TextColor="#757575" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Button Text="Continue with Google" 
                    BackgroundColor="#F5F5F5" TextColor="#424242" FontAttributes="Bold"
                    CornerRadius="25" HeightRequest="55" BorderWidth="1" BorderColor="#E0E0E0" Clicked="OnGoogleClicked" />

            <Button Text="Continue with Apple" 
                    BackgroundColor="#000000" TextColor="White" FontAttributes="Bold"
                    CornerRadius="25" HeightRequest="55" Clicked="OnAppleClicked" />

            <Grid ColumnDefinitions="*, Auto, *" Margin="0,10">
                <BoxView Grid.Column="0" HeightRequest="1" Color="#EEEEEE" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="or log in with email" TextColor="#9E9E9E" Margin="15,0" FontSize="14" VerticalOptions="Center"/>
                <BoxView Grid.Column="2" HeightRequest="1" Color="#EEEEEE" VerticalOptions="Center"/>
            </Grid>

            <Frame BorderColor="#E0E0E0" CornerRadius="15" HasShadow="False" Padding="15,5" BackgroundColor="#FAFAFA">
                <Entry Placeholder="Email address" Keyboard="Email" TextColor="#212121" ClearButtonVisibility="WhileEditing" />
            </Frame>

            <Frame BorderColor="#E0E0E0" CornerRadius="15" HasShadow="False" Padding="15,5" BackgroundColor="#FAFAFA">
                <Entry Placeholder="Password" IsPassword="True" TextColor="#212121" />
            </Frame>

            <Label Text="Forgot password?" TextColor="#E91E63" FontAttributes="Bold" HorizontalOptions="End" Margin="0,-10,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                </Label.GestureRecognizers>
            </Label>

            <Button Text="Log In" 
                    BackgroundColor="#E91E63" TextColor="White" FontAttributes="Bold" FontSize="16"
                    CornerRadius="25" HeightRequest="55" Margin="0,10,0,0" Clicked="OnLoginClicked"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Don't have an account?" TextColor="#757575" VerticalOptions="Center"/>
                <Label Text="Sign Up" TextColor="#E91E63" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Button x:Name="BtnGuest"
                    Text="Explore as Guest" 
                    BackgroundColor="Transparent" TextColor="#757575" FontAttributes="Bold"
                    Margin="0, 20, 0, 0" 
                    Clicked="BtnGuest_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>