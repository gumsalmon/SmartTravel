<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.Views.ShopDetailPage"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <Grid RowDefinitions="300, *">

        <!-- ═══ HERO IMAGE với Gradient Overlay ═══ -->
        <Grid Grid.Row="0">
            <Image x:Name="heroImage"
                   Source="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&amp;w=800"
                   Aspect="AspectFill" />

            <!-- Dark gradient overlay from transparent → dark -->
            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.0"/>
                        <GradientStop Color="#CC0D0D1A" Offset="0.7"/>
                        <GradientStop Color="#FF0D0D1A" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Back Button -->
            <Button Text="←" FontSize="20" FontAttributes="Bold"
                    TextColor="White" BackgroundColor="#44FFFFFF"
                    CornerRadius="22" WidthRequest="44" HeightRequest="44"
                    HorizontalOptions="Start" VerticalOptions="Start" Margin="15,50,0,0"
                    Clicked="BackButton_Clicked"/>

            <!-- TTS Floating Button -->
            <Button x:Name="ttsButton" Text="🔊 Nghe Thuyết Minh"
                    FontSize="13" FontAttributes="Bold"
                    TextColor="White" BackgroundColor="#1A73E8"
                    CornerRadius="20" HeightRequest="40" Padding="15,0"
                    HorizontalOptions="End" VerticalOptions="Start" Margin="0,55,15,0"
                    Clicked="PlayAudio_Clicked">
                <Button.Shadow>
                    <Shadow Brush="#1A73E8" Offset="0,4" Radius="12" Opacity="0.5"/>
                </Button.Shadow>
            </Button>

            <!-- Shop Name chèn đè lên ảnh góc dưới -->
            <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,20" Spacing="4">
                <Label Text="{Binding Name}"
                       FontSize="26" FontAttributes="Bold" TextColor="White"/>
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📍 Phố Ẩm Thực Vĩnh Khánh" FontSize="13" TextColor="#AAAACC"/>
                    <Label x:Name="lblStatus" Text="● Đang mở" FontSize="13"
                           TextColor="#4ADE80" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- ═══ CONTENT PANEL - Glassmorphism Dark ═══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="16,20,16,40">

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="#1AFFFFFF" StrokeThickness="1" Stroke="#33FFFFFF"
                            StrokeShape="RoundRectangle 14" Padding="12">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="⭐ 4.8" FontAttributes="Bold" FontSize="16" TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Đánh giá" FontSize="11" TextColor="#888AAA" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#1AFFFFFF" StrokeThickness="1" Stroke="#33FFFFFF"
                            StrokeShape="RoundRectangle 14" Padding="12">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label x:Name="lblVisits" Text="..." FontAttributes="Bold" FontSize="16" TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Lượt thăm" FontSize="11" TextColor="#888AAA" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="#1AFFFFFF" StrokeThickness="1" Stroke="#33FFFFFF"
                            StrokeShape="RoundRectangle 14" Padding="12">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label x:Name="lblRadius" Text="50m" FontAttributes="Bold" FontSize="16" TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Bán kính" FontSize="11" TextColor="#888AAA" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1" Color="#22FFFFFF"/>

                <!-- Subscription Status Banner -->
                <Border x:Name="subBanner" IsVisible="False"
                        BackgroundColor="#FFCC001A" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="14,10">
                    <Label x:Name="lblSubStatus" Text="⚠️ Gói cước đã hết hạn - Sạp này không còn hoạt động"
                           TextColor="White" FontSize="13" FontAttributes="Bold"/>
                </Border>

                <!-- Menu Section Header -->
                <Label Text="🍽️ Thực Đơn Nổi Bật" FontSize="18" FontAttributes="Bold" TextColor="White"/>

                <!-- Loading -->
                <ActivityIndicator x:Name="menuLoader" IsRunning="True" IsVisible="True" Color="#1A73E8"/>

                <!-- Dynamic menu list (populated from code) -->
                <VerticalStackLayout x:Name="menuContainer" Spacing="10"/>

                <!-- No menu fallback -->
                <Label x:Name="lblNoMenu" Text="☕ Menu đang được cập nhật..." IsVisible="False"
                       TextColor="#888AAA" FontSize="14" HorizontalOptions="Center" Margin="0,20"/>

                <BoxView HeightRequest="1" Color="#22FFFFFF" Margin="0,10"/>

                <!-- Location Info Card -->
                <Label Text="📍 Thông Tin Vị Trí" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                <Border BackgroundColor="#1AFFFFFF" StrokeThickness="1" Stroke="#33FFFFFF"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="lblCoords" Text="Đang lấy tọa độ..." TextColor="#AAAACC" FontSize="13"/>
                        <Label Text="Phố Ẩm Thực Vĩnh Khánh, Quận 4, TP.HCM" TextColor="#AAAACC" FontSize="13"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>