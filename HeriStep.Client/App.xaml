<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HeriStep.Client"
             xmlns:conv="clr-namespace:HeriStep.Client.Converters"
             x:Class="HeriStep.Client.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Free Discovery Converters ── -->
            <conv:InvertBoolConverter       x:Key="InvertBool" />
            <conv:BoolToStartStopConverter  x:Key="BoolToStartStop" />
            <conv:BoolToButtonColorConverter x:Key="BoolToBtnColor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
