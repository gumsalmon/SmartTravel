<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C1C1C">

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,120" Spacing="0">

            <!-- ══════════════════════════════════════════════ -->
            <!-- HEADER BAR                                      -->
            <!-- ══════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,52,20,18" BackgroundColor="#1C1C1C">
                <Button Text="☰" FontSize="20" TextColor="#D35400" BackgroundColor="Transparent"
                        Padding="0" Margin="0" Grid.Column="0" Clicked="OnMenuClicked"/>
                <Label x:Name="lblMainHeader" Text="PHỐ VĨNH KHÁNH" FontSize="15" FontAttributes="Bold"
                       TextColor="#FDF5E6" HorizontalOptions="Center" VerticalOptions="Center"
                       Grid.Column="1" CharacterSpacing="1"/>
                <Border StrokeShape="RoundRectangle 20" HeightRequest="40" WidthRequest="40"
                        StrokeThickness="2" Stroke="#D35400" Grid.Column="2">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                    </Border.GestureRecognizers>
                    <Image Source="https://images.unsplash.com/photo-1599566150163-29194dcaad36?q=80&amp;w=200"
                           Aspect="AspectFill"/>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════ -->
            <!-- HERO BANNER                                     -->
            <!-- ══════════════════════════════════════════════ -->
            <Border StrokeShape="RoundRectangle 0" StrokeThickness="0" Margin="0,0,0,0" HeightRequest="360">
                <Grid>
                    <Image Source="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&amp;w=800"
                           Aspect="AspectFill" Opacity="0.55"/>
                    <!-- Dark overlay -->
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#AA1C1C1C" Offset="0.0"/>
                                <GradientStop Color="#551C1C1C" Offset="0.4"/>
                                <GradientStop Color="#FF1C1C1C" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <!-- Left amber gradient -->
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#881C1C1C" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="0.7"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <!-- Text content -->
                    <VerticalStackLayout Padding="28,40" Spacing="16" VerticalOptions="End" HorizontalOptions="Fill">
                        <Border StrokeShape="RoundRectangle 8" BackgroundColor="#40D35400"
                                Padding="12,6" StrokeThickness="1" Stroke="#D35400"
                                HorizontalOptions="Center">
                            <Label x:Name="lblHeroTag" Text="QUẬN 4 · SAIGON" FontSize="10" FontAttributes="Bold"
                                   TextColor="#D35400" CharacterSpacing="2"/>
                        </Border>
                        <Label x:Name="lblHeroTitle" Text="Khám Phá Tâm Hồn Quận 4"
                               FontSize="42" FontAttributes="Bold" TextColor="#FDF5E6" LineHeight="1.1"
                               HorizontalTextAlignment="Center" HorizontalOptions="Center" MaxLines="2" LineBreakMode="WordWrap"/>
                        
                        <!-- Search Bar -->
                        <Border BackgroundColor="#EE242424" StrokeThickness="1" Stroke="#50D35400"
                                StrokeShape="RoundRectangle 24" Padding="12,0" Margin="10,10,10,0" HeightRequest="48">
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Text="🔍" FontSize="18" Grid.Column="0" VerticalOptions="Center" Margin="6,0,8,0"/>
                                <Entry x:Name="heroSearchEntry"
                                       Placeholder="Tìm quán ăn, địa điểm..."
                                       PlaceholderColor="#6B5B4E"
                                       TextColor="#FDF5E6"
                                       BackgroundColor="Transparent"
                                       Grid.Column="1"
                                       VerticalOptions="Center"
                                       Completed="OnHeroSearchCompleted"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════ -->
            <!-- QUICK ACTIONS                                   -->
            <!-- ══════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Padding="20,20,20,4">
                <!-- Map action -->
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="#2A2A2A"
                        Padding="16,18" StrokeThickness="0" Grid.Column="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BtnMap_Clicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 14" HeightRequest="48" WidthRequest="48"
                                BackgroundColor="#3D1A00" Padding="0" StrokeThickness="0" HorizontalOptions="Center">
                            <Label Text="🗺️" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="lblQuickMap" Text="Bản Đồ" FontSize="13" FontAttributes="Bold"
                               TextColor="#FDF5E6" HorizontalOptions="Center"/>
                        <Label x:Name="lblQuickMapDesc" Text="Khám phá gần bạn" FontSize="10" TextColor="#6B5B4E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Top Stalls action -->
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="#2A2A2A"
                        Padding="16,18" StrokeThickness="0" Grid.Column="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BtnShop_Clicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 14" HeightRequest="48" WidthRequest="48"
                                BackgroundColor="#3D2600" Padding="0" StrokeThickness="0" HorizontalOptions="Center">
                            <Label Text="🏪" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="lblQuickTop" Text="Top Quán" FontSize="13" FontAttributes="Bold"
                               TextColor="#FDF5E6" HorizontalOptions="Center"/>
                        <Label x:Name="lblQuickTopDesc" Text="Được yêu thích nhất" FontSize="10" TextColor="#6B5B4E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TOP STALLS SECTION                             -->
            <!-- ══════════════════════════════════════════════ -->
            <VerticalStackLayout Spacing="14" Padding="20,16,20,0">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="lblTopSection" Text="Quán Đỉnh Phải Thử" FontSize="20"
                               FontAttributes="Bold" TextColor="#FDF5E6"/>
                        <Label x:Name="lblTopSectionDesc" Text="Top rating từ cộng đồng thực thần"
                               FontSize="12" TextColor="#6B5B4E"/>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" VerticalOptions="End" Spacing="3">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="BtnMap_Clicked"/>
                        </HorizontalStackLayout.GestureRecognizers>
                        <Label x:Name="lblViewAll" Text="Xem tất cả" FontSize="12" FontAttributes="Bold" TextColor="#D35400"/>
                        <Label Text="→" FontSize="13" FontAttributes="Bold" TextColor="#D35400"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="-20,0">
                    <HorizontalStackLayout Spacing="14" Padding="20,0">
                        <!-- Card 1 -->
                        <VerticalStackLayout Spacing="8" WidthRequest="220">
                            <Border StrokeShape="RoundRectangle 18" Padding="0" StrokeThickness="0"
                                    HeightRequest="270" BackgroundColor="#2A2A2A">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="BtnShop_Clicked"/>
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Image Source="https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=600"
                                           Aspect="AspectFill"/>
                                    <BoxView VerticalOptions="End" HeightRequest="90">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="#EE1C1C1C" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                    <!-- Rating pill -->
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#D35400"
                                            Padding="8,3" StrokeThickness="0"
                                            HorizontalOptions="End" VerticalOptions="Start" Margin="10">
                                        <Label Text="★ 4.9" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Label Text="Ốc Oanh Vĩnh Khánh" FontSize="14" FontAttributes="Bold"
                                   TextColor="#FDF5E6" Margin="4,0"/>
                            <Label x:Name="lblShop1Tags" Text="🐌 Hải sản · Ốc các loại" FontSize="11" TextColor="#6B5B4E"
                                   Margin="4,0"/>
                        </VerticalStackLayout>
                        <!-- Card 2 -->
                        <VerticalStackLayout Spacing="8" WidthRequest="220">
                            <Border StrokeShape="RoundRectangle 18" Padding="0" StrokeThickness="0"
                                    HeightRequest="270" BackgroundColor="#2A2A2A">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="BtnShop2_Clicked"/>
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Image Source="https://images.unsplash.com/photo-1574484284002-952d92456975?w=600"
                                           Aspect="AspectFill"/>
                                    <BoxView VerticalOptions="End" HeightRequest="90">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="#EE1C1C1C" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#D35400"
                                            Padding="8,3" StrokeThickness="0"
                                            HorizontalOptions="End" VerticalOptions="Start" Margin="10">
                                        <Label Text="★ 4.8" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Label Text="Bà Kẹp Vĩnh Khánh" FontSize="14" FontAttributes="Bold"
                                   TextColor="#FDF5E6" Margin="4,0"/>
                            <Label x:Name="lblShop2Tags" Text="🥢 Ăn vặt · Đường phố" FontSize="11" TextColor="#6B5B4E"
                                   Margin="4,0"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ══════════════════════════════════════════════ -->
            <!-- 🎙️ VOICE CUSTOMIZATION STUDIO                  -->
            <!-- ══════════════════════════════════════════════ -->
            <Border StrokeShape="RoundRectangle 28" BackgroundColor="#242424"
                    StrokeThickness="1" Stroke="#3D1A00"
                    Padding="22,24" Margin="20,24,20,10">
                <Border.Shadow>
                    <Shadow Brush="#D35400" Offset="0,4" Radius="20" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="20">

                    <!-- Studio Header -->
                    <HorizontalStackLayout Spacing="12">
                        <Border StrokeShape="RoundRectangle 14" BackgroundColor="#3D1A00"
                                HeightRequest="44" WidthRequest="44" Padding="0" StrokeThickness="0">
                            <Label Text="🎙️" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                            <Label x:Name="lblVoiceTag" Text="VOICE STUDIO" FontSize="9" FontAttributes="Bold"
                                   TextColor="#D35400" CharacterSpacing="2"/>
                            <Label x:Name="lblVoiceTitle" Text="Customization" FontSize="18" FontAttributes="Bold"
                                   TextColor="#FDF5E6"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Label x:Name="lblVoiceDesc" Text="Select a voice, type your text, and preview it instantly."
                           FontSize="13" TextColor="#6B5B4E" LineHeight="1.4"/>

                    <!-- Voice Profile Row -->
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="lblVoiceProfileRow" Text="VOICE PROFILE" FontSize="9" FontAttributes="Bold"
                               TextColor="#6B5B4E" CharacterSpacing="1.5"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <!-- Female Voice -->
                            <Border x:Name="btnVoiceFemale" Grid.Column="0"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="2"
                                    Stroke="#D35400" BackgroundColor="#3D1A00" Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGenderTapped" CommandParameter="female"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="👩🏼" FontSize="20" HorizontalOptions="Center"/>
                                    <Label Text="Giọng Nữ" FontSize="11" FontAttributes="Bold" TextColor="#FDF5E6" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Male Voice -->
                            <Border x:Name="btnVoiceMale" Grid.Column="1"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="1"
                                    Stroke="#3A3A3A" BackgroundColor="#2A2A2A" Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGenderTapped" CommandParameter="male"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="👨🏻" FontSize="20" HorizontalOptions="Center"/>
                                    <Label Text="Giọng Nam" FontSize="11" FontAttributes="Bold" TextColor="#B0A090" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                        
                        <!-- Language Picker -->
                        <Label Text="Ngôn Ngữ" FontSize="9" FontAttributes="Bold" TextColor="#6B5B4E" CharacterSpacing="1.5" Margin="0,5,0,0"/>
                        <Border StrokeShape="RoundRectangle 14" BackgroundColor="#1C1C1C" Padding="10,0" StrokeThickness="1" Stroke="#3A3A3A" HeightRequest="44">
                            <Picker x:Name="pickerLanguage" TextColor="#FDF5E6" Title="Chọn ngôn ngữ đọc" TitleColor="#6B5B4E" SelectedIndexChanged="OnLanguagePickerChanged">
                                <Picker.Items>
                                    <x:String>🇻🇳 Tiếng Việt (Vietnamese)</x:String>
                                    <x:String>🇬🇧 English</x:String>
                                    <x:String>🇰🇷 한국어 (Korean)</x:String>
                                    <x:String>🇯🇵 日本語 (Japanese)</x:String>
                                    <x:String>🇫🇷 Français (French)</x:String>
                                    <x:String>🇪🇸 Español (Spanish)</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Text Input -->
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="lblVoiceTextRow" Text="YOUR TEXT" FontSize="9" FontAttributes="Bold"
                                   TextColor="#6B5B4E" CharacterSpacing="1.5" Grid.Column="0"/>
                            <Label x:Name="lblCharCount" Text="0 / 300" FontSize="9"
                                   TextColor="#6B5B4E" Grid.Column="1"/>
                        </Grid>
                        <Border StrokeShape="RoundRectangle 16" BackgroundColor="#1C1C1C"
                                Padding="4,0" StrokeThickness="1" Stroke="#3A3A3A">
                            <Editor x:Name="voiceTextInput"
                                    Placeholder="Nhập văn bản để nghe thử..."
                                    PlaceholderColor="#4A4A4A"
                                    TextColor="#FDF5E6"
                                    BackgroundColor="Transparent"
                                    HeightRequest="88"
                                    MaxLength="300"
                                    FontSize="14"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Speed Row -->
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="lblVoiceSpeedRow" Text="SPEED" FontSize="9" FontAttributes="Bold"
                                   TextColor="#6B5B4E" CharacterSpacing="1.5" Grid.Column="0"/>
                            <Label x:Name="lblSpeedVal" Text="1.0×" FontSize="12"
                                   FontAttributes="Bold" TextColor="#D35400" Grid.Column="1"/>
                        </Grid>
                        <Slider x:Name="voiceSpeedSlider" Minimum="0.5" Maximum="2.0" Value="1.0"
                                ThumbColor="#D35400" MinimumTrackColor="#D35400"
                                MaximumTrackColor="#3A3A3A" ValueChanged="OnSpeedChanged"/>
                    </VerticalStackLayout>

                    <!-- TEST VOICE Button -->
                    <Button x:Name="btnTestVoice"
                            Text="▶   TEST VOICE"
                            CornerRadius="22"
                            BackgroundColor="#D35400"
                            TextColor="#FDF5E6"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="52"
                            CharacterSpacing="0.5"
                            Clicked="OnTestVoiceClicked">
                        <Button.Shadow>
                            <Shadow Brush="#D35400" Offset="0,6" Radius="18" Opacity="0.5"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Status -->
                    <Label x:Name="lblVoiceStatus"
                           Text="💡 Select a voice, enter text, then tap Test Voice"
                           FontSize="12" TextColor="#6B5B4E"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>