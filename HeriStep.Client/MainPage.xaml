<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStep.Client.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D1A">

    <Grid RowDefinitions="Auto, *">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" BackgroundColor="#0D0D1A" StrokeThickness="0" Padding="16,50,16,14">
            <VerticalStackLayout Spacing="4">
                <Label Text="🏪 Danh Sách Cửa Hàng" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                <Label x:Name="lblCount" Text="Đang tải..." FontSize="13" TextColor="#888AAA"/>
            </VerticalStackLayout>
        </Border>

        <!-- ═══ LOADING ═══ -->
        <ActivityIndicator x:Name="loader" Grid.Row="1" IsRunning="True" IsVisible="True"
                           Color="#4285F4" VerticalOptions="Center"/>

        <!-- ═══ DANH SÁCH SẠP ═══ -->
        <CollectionView x:Name="stallList" Grid.Row="1" Margin="12,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" BackgroundColor="#1AFFFFFF"
                            StrokeThickness="1" Stroke="#22FFFFFF"
                            StrokeShape="RoundRectangle 14" Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStallTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="100, *" HeightRequest="90">
                            <!-- Ảnh -->
                            <Image Source="{Binding DisplayImageUrl}" Aspect="AspectFill"
                                   Grid.Column="0"/>

                            <!-- Thông tin -->
                            <VerticalStackLayout Grid.Column="1" Padding="12,10" Spacing="4"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold"
                                       TextColor="White" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding DisplayOwner}" FontSize="12" TextColor="#AAAACC"/>
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding DisplayStatus}" FontSize="11"
                                           FontAttributes="Bold"/>
                                    <Label Text="📍 Vĩnh Khánh, Q4" FontSize="11" TextColor="#666688"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ═══ EMPTY STATE ═══ -->
        <VerticalStackLayout x:Name="emptyState" Grid.Row="1" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Label Text="🏚️" FontSize="50" HorizontalOptions="Center"/>
            <Label Text="Chưa có cửa hàng nào" FontSize="16" TextColor="#888AAA" HorizontalOptions="Center"/>
            <Label Text="Vui lòng tạo dữ liệu từ Admin" FontSize="13" TextColor="#666688" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>